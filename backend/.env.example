# =============================================================================
#  AgriGrant AI — Backend Environment Template
#  Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
PORT=8000
CHAT_SESSION_SECRET=change-me-to-a-long-random-string

# ── UiPath Auth (Personal Access Token is the supported path) ────────────────
UIPATH_PAT=
UIPATH_BASE_URL=https://staging.uipath.com
UIPATH_ORGANIZATION=
UIPATH_TENANT=DefaultTenant

# OAuth client_credentials — leave blank, PAT is preferred
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=

# ── UiPath Orchestrator targets ──────────────────────────────────────────────
UIPATH_FOLDER_ID=
UIPATH_FOLDER_KEY=

# Maestro Pipeline + AgriGrant API trigger URLs (preferred entry points)
UIPATH_PIPELINE_TRIGGER_URL=
UIPATH_API_TRIGGER_URL=

# Release keys (for direct StartJobs fallback only — normally unused)
UIPATH_PIPELINE_PROCESS_KEY=
UIPATH_API_WORKFLOW_PROCESS_KEY=
UIPATH_FORM_FILLER_ROBOT_KEY=

# Agent release keys
UIPATH_GRANT_DISCOVERY_AGENT_KEY=
UIPATH_ELIGIBILITY_AGENT_KEY=
UIPATH_DOCUMENT_UNDERSTANDING_AGENT_KEY=
UIPATH_PROPOSAL_AGENT_KEY=
UIPATH_SUBMISSION_AGENT_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@agrigrant.xyz
SENDGRID_FROM_NAME=AgriGrant AI

# ── LLM (OpenRouter) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
LLM_MODEL=google/gemini-2.5-flash

# ── Tunnel (only used by `docker compose --profile tunnel up`) ───────────────
NGROK_AUTHTOKEN=
