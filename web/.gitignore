# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/
build/
*.tsbuildinfo
next-env.d.ts

# ─── Environment & Secrets ────────────────────────────────────────────────────
# Never commit real credentials
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# Keep example files so devs know what vars are needed
!.env.example
!.env.local.example

# ─── Package manager locks (pick one to commit, ignore the rest) ──────────────
# Commit package-lock.json OR yarn.lock, not both
# Uncomment whichever you don't use:
# package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ─── Test & Coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/
jest-test-results.json
playwright-report/
test-results/

# ─── OS-specific ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

