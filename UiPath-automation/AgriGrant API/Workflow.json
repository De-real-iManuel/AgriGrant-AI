{
  "document": {
    "dsl": "1.0.0",
    "name": "Workflow",
    "tags": {
      "projectId": "4f9209fa-5611-40be-9c73-896370433e8b",
      "solutionId": "3a4257ff-ce33-4a90-be65-08dec08e2a71"
    },
    "version": "0.0.1",
    "namespace": "default",
    "metadata": {
      "variables": {
        "schema": {
          "format": "json",
          "document": {
            "type": "object",
            "properties": {
              "applicationRef": {
                "type": "string",
                "default": ""
              },
              "status": {
                "type": "string",
                "default": ""
              },
              "grantDiscoveryResult": {
                "type": "object",
                "default": ""
              },
              "eligibilityResult": {
                "type": "object",
                "default": ""
              },
              "proposalResult": {
                "type": "object",
                "default": ""
              },
              "submissionResult": {
                "type": "object",
                "default": ""
              },
              "validationError": {
                "type": "string",
                "default": ""
              },
              "applicationReference": {
                "type": "string",
                "default": ""
              },
              "submissionStatus": {
                "type": "string",
                "default": ""
              },
              "confirmationEmailSent": {
                "type": "boolean",
                "default": "false"
              },
              "applicationLetterHTML": {
                "type": "string",
                "default": ""
              },
              "applicationLetterText": {
                "type": "string",
                "default": ""
              },
              "message": {
                "type": "string",
                "default": ""
              },
              "topGrant": {
                "type": "object",
                "default": ""
              },
              "documentStatus": {
                "type": "string",
                "default": ""
              },
              "documentReadinessScore": {
                "type": "number",
                "default": ""
              },
              "emailSent": {
                "type": "boolean",
                "default": "false"
              }
            }
          }
        }
      }
    }
  },
  "input": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "farmerName": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "farmLocation": {
            "type": "string"
          },
          "farmType": {
            "type": "string"
          },
          "cropOrLivestockTypes": {
            "type": "string"
          },
          "farmSizeHectares": {
            "type": "number"
          },
          "annualRevenueNGN": {
            "type": "number"
          },
          "requestedFundingAmountNGN": {
            "type": "number"
          },
          "ownershipStatus": {
            "type": "string"
          },
          "hasBVN": {
            "type": "boolean"
          },
          "hasCACRegistration": {
            "type": "boolean"
          },
          "isMemberOfCooperative": {
            "type": "boolean"
          },
          "hasLandDocument": {
            "type": "boolean"
          },
          "hasFarmBusinessPlan": {
            "type": "boolean"
          },
          "hasExistingLoanDefault": {
            "type": "boolean"
          },
          "isSmallholderFarmer": {
            "type": "boolean"
          },
          "isYouthFarmer": {
            "type": "boolean"
          },
          "isWomanFarmer": {
            "type": "boolean"
          },
          "proposedProjectDescription": {
            "type": "string"
          },
          "submittedDocuments": {
            "type": "string"
          }
        },
        "required": [
          "farmerName",
          "phoneNumber",
          "farmLocation",
          "farmType",
          "farmSizeHectares",
          "requestedFundingAmountNGN",
          "hasBVN",
          "hasCACRegistration",
          "hasExistingLoanDefault",
          "proposedProjectDescription"
        ]
      }
    }
  },
  "do": [
    {
      "sequence_1": {
        "do": [
          {
            "WorkflowStart": {
              "set": "${Object.entries($workflow.definition?.document?.metadata?.variables?.schema?.document?.properties || {}).reduce((acc, [name, def]) => ({ ...acc, [name]: def?.default }), {}) }",
              "output": {
                "as": "${$input}"
              },
              "export": {
                "as": "{ ...$context, variables: { ...$context.variables, ...$output } }"
              },
              "metadata": {
                "activityType": "Assign",
                "displayName": "Workflow start",
                "fullName": "Assign",
                "isTransparent": true
              }
            }
          },
          {
            "Assign_ApplicationRef": {
              "set": {
                "applicationRef": "${'AGRI-' + Date.now()}"
              },
              "export": {
                "as": "{ ...$context, variables: { ...$context.variables, ...$output } }"
              },
              "metadata": {
                "activityType": "Assign",
                "displayName": "Create a unique application reference number",
                "fullName": "Assign",
                "isTransparent": false,
                "outputName": "Assign_ApplicationRef"
              }
            }
          },
          {
            "If_Check_Criteria#Wrapper": {
              "do": [
                {
                  "If_Check_Criteria": {
                    "switch": [
                      {
                        "case": {
                          "when": "${$workflow.input.farmerName && $workflow.input.hasBVN === true && $workflow.input.hasExistingLoanDefault === false}",
                          "then": "If_Check_Criteria#Then"
                        }
                      },
                      {
                        "default": {
                          "then": "If_Check_Criteria#Else"
                        }
                      }
                    ],
                    "metadata": {
                      "displayName": "Check if the application meets the initial acceptance criteria"
                    }
                  }
                },
                {
                  "If_Check_Criteria#Then": {
                    "do": [
                      {
                        "Assign_Accepted": {
                          "set": {
                            "status": "${\"ACCEPTED\"}"
                          },
                          "export": {
                            "as": "{ ...$context, variables: { ...$context.variables, ...$output } }"
                          },
                          "metadata": {
                            "activityType": "Assign",
                            "displayName": "Set status to ACCEPTED",
                            "fullName": "Assign",
                            "isTransparent": false,
                            "outputName": "Assign_Accepted"
                          }
                        }
                      }
                    ],
                    "then": "exit"
                  }
                },
                {
                  "If_Check_Criteria#Else": {
                    "do": [
                      {
                        "Assign_Rejected": {
                          "set": {
                            "status": "${\"REJECTED\"}"
                          },
                          "export": {
                            "as": "{ ...$context, variables: { ...$context.variables, ...$output } }"
                          },
                          "metadata": {
                            "activityType": "Assign",
                            "displayName": "Set status to REJECTED",
                            "fullName": "Assign",
                            "isTransparent": false,
                            "outputName": "Assign_Rejected"
                          }
                        }
                      }
                    ],
                    "then": "exit"
                  }
                }
              ],
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"If_Check_Criteria\": $output } }"
              },
              "metadata": {
                "activityType": "If",
                "displayName": "Check if the application meets the initial acceptance criteria",
                "fullName": "If",
                "outputName": "If_Check_Criteria"
              }
            }
          },
          {
            "Return_Response": {
              "response": "${{\"applicationRef\": $context.variables.applicationRef, \"status\": $context.variables.status, \"farmerName\": $workflow.input.farmerName}}",
              "markJobAsFailed": false,
              "then": "end",
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"Return_Response\": $output } }"
              },
              "metadata": {
                "activityType": "Response",
                "displayName": "Return the final application status and reference",
                "fullName": "Response",
                "outputName": "Return_Response"
              }
            }
          }
        ],
        "metadata": {
          "activityType": "Sequence",
          "displayName": "Sequence",
          "fullName": "Sequence",
          "outputName": "sequence_1"
        }
      }
    }
  ],
  "evaluate": {
    "mode": "strict",
    "language": "javascript"
  }
}