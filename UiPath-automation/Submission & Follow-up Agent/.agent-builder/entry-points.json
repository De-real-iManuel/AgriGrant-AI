{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "$id": "entry-points.json",
  "entryPoints": [
    {
      "filePath": "/content/agent.json",
      "type": "agent",
      "uniqueId": "af423104-1c90-45be-9141-474e47ad0e04",
      "input": {
        "type": "object",
        "required": [
          "farmerName",
          "farmerPhone",
          "stateOfResidence",
          "grantName",
          "grantingOrganization",
          "projectTitle",
          "requestedAmountNGN",
          "submissionDeadline",
          "submissionMethod",
          "currentStatus",
          "documentsChecklist",
          "agentAction",
          "preferredLanguage"
        ],
        "properties": {
          "farmerName": {
            "type": "string",
            "description": "Full name of the Nigerian farmer. Used to personalize all messages and notifications."
          },
          "farmerPhone": {
            "type": "string",
            "description": "Nigerian mobile phone number of the farmer (e.g., '+2348012345678')."
          },
          "farmerEmail": {
            "type": "string",
            "description": "Optional: Farmer's email address. Used for milestone emails only. Omit if not available."
          },
          "stateOfResidence": {
            "type": "string",
            "description": "Nigerian state where the farmer is based. Used to tailor submission office addresses."
          },
          "grantName": {
            "type": "string",
            "description": "Official name of the grant being submitted (e.g., 'CBN Anchor Borrowers Programme')."
          },
          "grantingOrganization": {
            "type": "string",
            "description": "Full name of the granting organization."
          },
          "projectTitle": {
            "type": "string",
            "description": "Title of the grant project as written in the proposal."
          },
          "requestedAmountNGN": {
            "type": "number",
            "description": "Total grant amount requested in NGN.",
            "minimum": 0
          },
          "submissionDeadline": {
            "type": "string",
            "description": "Application deadline in ISO format or descriptive (e.g., '2026-07-31' or 'Rolling')."
          },
          "submissionMethod": {
            "type": "string",
            "description": "How the application is submitted.",
            "enum": [
              "online-portal",
              "email",
              "physical-office",
              "bank-branch",
              "cooperative-office",
              "mixed"
            ]
          },
          "submissionPortalUrl": {
            "type": "string",
            "description": "Optional: URL of the online submission portal."
          },
          "submissionOfficeAddress": {
            "type": "string",
            "description": "Optional: Physical address of the submission office."
          },
          "submissionContactEmail": {
            "type": "string",
            "description": "Optional: Official email to submit to or follow up with."
          },
          "submissionContactPhone": {
            "type": "string",
            "description": "Optional: Phone number of the grant office."
          },
          "applicationReferenceNumber": {
            "type": "string",
            "description": "Optional: Tracking number received after submission."
          },
          "submissionDate": {
            "type": "string",
            "description": "Optional: Date the application was submitted (YYYY-MM-DD)."
          },
          "currentStatus": {
            "type": "string",
            "description": "Current status of the grant application.",
            "enum": [
              "not-yet-submitted",
              "submitted-awaiting-acknowledgement",
              "acknowledged",
              "under-review",
              "additional-info-requested",
              "approved",
              "rejected",
              "on-hold"
            ]
          },
          "documentsChecklist": {
            "type": "array",
            "description": "List of all documents prepared for submission.",
            "items": {
              "type": "string"
            }
          },
          "missingDocuments": {
            "type": "array",
            "description": "Optional: Documents that are missing or incomplete.",
            "items": {
              "type": "string"
            }
          },
          "agentAction": {
            "type": "string",
            "description": "The primary task to perform. 'respond-to-farmer-chat' = natural language conversation with farmer in the web app (NEVER triggers email).",
            "enum": [
              "prepare-submission-package",
              "generate-confirmation",
              "set-reminders",
              "track-and-follow-up",
              "handle-additional-info-request",
              "generate-rejection-response",
              "respond-to-farmer-chat"
            ]
          },
          "chatMessage": {
            "type": "string",
            "description": "The farmer's natural language message when agentAction is 'respond-to-farmer-chat'. This is what the farmer typed in the web app chat interface (e.g., 'What stage is my grant at?', 'When will I hear back?', 'What documents do I still need?'). Omit for all other actions."
          },
          "chatHistory": {
            "type": "array",
            "description": "Optional: Previous chat messages for conversation context when agentAction is 'respond-to-farmer-chat'. Each item is an object with 'role' (farmer/agent) and 'message'. Omit for first message or other actions.",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string",
                  "enum": [
                    "farmer",
                    "agent"
                  ]
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "additionalInfoRequested": {
            "type": "string",
            "description": "Optional: Details of additional info requested by grantor. Required when agentAction is 'handle-additional-info-request'."
          },
          "rejectionReason": {
            "type": "string",
            "description": "Optional: Reason for rejection. Required when agentAction is 'generate-rejection-response'."
          },
          "preferredLanguage": {
            "type": "string",
            "description": "Language tone for farmer-facing messages.",
            "enum": [
              "english",
              "pidgin-english",
              "bilingual-english-pidgin"
            ]
          },
          "additionalNotes": {
            "type": "string",
            "description": "Optional: Extra context (e.g., 'Farmer has limited literacy', 'This is a second application')."
          }
        },
        "title": "Inputs"
      },
      "output": {
        "type": "object",
        "required": [
          "farmerName",
          "grantName",
          "agentAction",
          "currentStatus",
          "webAppNotification",
          "farmerFacingMessagePrimary",
          "emailPayload",
          "agentSummary"
        ],
        "properties": {
          "farmerName": {
            "type": "string",
            "description": "Full name of the farmer, echoed from input."
          },
          "grantName": {
            "type": "string",
            "description": "Name of the grant, echoed from input."
          },
          "agentAction": {
            "type": "string",
            "description": "Action performed, echoed from input."
          },
          "currentStatus": {
            "type": "string",
            "description": "Current application status, echoed from input."
          },
          "webAppNotification": {
            "type": "object",
            "description": "ALWAYS required. Notification pushed to the farmer's Next.js web app dashboard. This is the PRIMARY communication channel.",
            "required": [
              "type",
              "title",
              "message",
              "actionRequired",
              "timestamp"
            ],
            "properties": {
              "type": {
                "type": "string",
                "description": "Notification category for the web app UI.",
                "enum": [
                  "info",
                  "action-required",
                  "milestone",
                  "warning",
                  "chat-response",
                  "celebration"
                ]
              },
              "title": {
                "type": "string",
                "description": "Short notification title (max 60 chars) for the notification panel (e.g., 'Your grant application was submitted!', 'Action needed: Upload bank statement', 'Grant status update')."
              },
              "message": {
                "type": "string",
                "description": "Notification body (max 200 words). Clear, friendly, matches preferredLanguage. Ends with one actionable next step."
              },
              "actionRequired": {
                "type": "boolean",
                "description": "True if the farmer needs to do something. False for informational updates."
              },
              "actionUrl": {
                "type": "string",
                "description": "Optional: Deep link in the web app for the farmer to take action (e.g., '/upload-documents', '/review-proposal', '/chat'). Omit if no action needed."
              },
              "timestamp": {
                "type": "string",
                "description": "ISO timestamp when this notification was generated."
              },
              "stage": {
                "type": "string",
                "description": "Current pipeline stage for the progress tracker UI.",
                "enum": [
                  "discovery",
                  "eligibility",
                  "documents",
                  "proposal",
                  "review",
                  "submission",
                  "monitoring",
                  "completed",
                  "rejected"
                ]
              }
            }
          },
          "chatResponse": {
            "type": "string",
            "description": "Present ONLY when agentAction is 'respond-to-farmer-chat'. Natural language response to the farmer's chat message. Conversational, warm, helpful, under 200 words. Matches preferredLanguage. Answers their question using grant context and suggests next steps. Empty string for all other actions."
          },
          "emailPayload": {
            "type": "object",
            "description": "Email notification structure. ALWAYS present in output BUT `sendEmail` controls whether it actually gets delivered. Only set sendEmail=true for MILESTONES: generate-confirmation, handle-additional-info-request, generate-rejection-response, and urgent track-and-follow-up.",
            "required": [
              "to",
              "subject",
              "htmlBody",
              "plainTextBody",
              "sendEmail",
              "emailType"
            ],
            "properties": {
              "to": {
                "type": "string",
                "description": "Farmer's email address. Empty string if not provided."
              },
              "subject": {
                "type": "string",
                "description": "Email subject line personalized with farmer name."
              },
              "htmlBody": {
                "type": "string",
                "description": "Complete HTML email body. Only fully populated when sendEmail is true. Set to empty string when sendEmail is false."
              },
              "plainTextBody": {
                "type": "string",
                "description": "Plain text email body. Only populated when sendEmail is true."
              },
              "sendEmail": {
                "type": "boolean",
                "description": "TRUE = this is a milestone, actually send the email. FALSE = not a milestone, skip email delivery. Pipeline uses this flag to decide whether to send."
              },
              "emailType": {
                "type": "string",
                "description": "Type of email matching agentAction.",
                "enum": [
                  "prepare-submission-package",
                  "generate-confirmation",
                  "set-reminders",
                  "track-and-follow-up",
                  "handle-additional-info-request",
                  "generate-rejection-response",
                  "respond-to-farmer-chat"
                ]
              }
            }
          },
          "submissionPackage": {
            "type": "object",
            "description": "Present only when agentAction is 'prepare-submission-package'.",
            "properties": {
              "readinessAssessment": {
                "type": "string",
                "enum": [
                  "Ready to Submit",
                  "Almost Ready — Minor Issues",
                  "Not Ready — Critical Items Missing"
                ]
              },
              "coverLetter": {
                "type": "string",
                "description": "Complete formal cover letter to the granting organization."
              },
              "documentsChecklistVerified": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "document": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "Ready",
                        "Missing",
                        "Needs Update"
                      ]
                    },
                    "note": {
                      "type": "string"
                    }
                  }
                }
              },
              "submissionGuide": {
                "type": "string",
                "description": "5–8 step submission guide."
              },
              "criticalWarnings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "submissionTips": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "confirmationPackage": {
            "type": "object",
            "description": "Present only when agentAction is 'generate-confirmation'.",
            "properties": {
              "congratulatoryMessage": {
                "type": "string",
                "description": "150–200 word celebration message."
              },
              "smsMessage": {
                "type": "string",
                "description": "SMS (max 160 chars)."
              },
              "whatsappMessage": {
                "type": "string",
                "description": "WhatsApp message (150–250 words)."
              },
              "submissionSummaryCard": {
                "type": "object",
                "properties": {
                  "farmerName": {
                    "type": "string"
                  },
                  "grantName": {
                    "type": "string"
                  },
                  "projectTitle": {
                    "type": "string"
                  },
                  "amountRequested": {
                    "type": "string"
                  },
                  "submissionDate": {
                    "type": "string"
                  },
                  "referenceNumber": {
                    "type": "string"
                  },
                  "expectedResponseTime": {
                    "type": "string"
                  },
                  "nextStep": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "reminderSchedule": {
            "type": "object",
            "description": "Present only when agentAction is 'set-reminders'.",
            "properties": {
              "totalReminders": {
                "type": "integer"
              },
              "reminders": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "reminderNumber": {
                      "type": "integer"
                    },
                    "triggerEvent": {
                      "type": "string"
                    },
                    "suggestedDate": {
                      "type": "string"
                    },
                    "channel": {
                      "type": "string",
                      "enum": [
                        "push-notification",
                        "SMS",
                        "WhatsApp",
                        "Email"
                      ]
                    },
                    "message": {
                      "type": "string",
                      "description": "100–200 word reminder matching preferredLanguage."
                    },
                    "actionRequired": {
                      "type": "string"
                    }
                  }
                }
              },
              "calendarSummary": {
                "type": "string"
              }
            }
          },
          "trackingAndFollowUp": {
            "type": "object",
            "description": "Present only when agentAction is 'track-and-follow-up'.",
            "properties": {
              "statusAssessment": {
                "type": "string"
              },
              "urgencyLevel": {
                "type": "string",
                "enum": [
                  "Routine",
                  "Follow-Up Due",
                  "Action Required",
                  "Urgent"
                ]
              },
              "followUpEmailDraft": {
                "type": "string",
                "description": "Formal follow-up email to grant office."
              },
              "followUpWhatsappMessage": {
                "type": "string"
              },
              "phoneScriptForFollowUp": {
                "type": "string"
              },
              "nextActions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "action": {
                      "type": "string"
                    },
                    "timeline": {
                      "type": "string"
                    },
                    "channel": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "additionalInfoResponse": {
            "type": "object",
            "description": "Present only when agentAction is 'handle-additional-info-request'.",
            "properties": {
              "acknowledgementLetter": {
                "type": "string"
              },
              "itemsToProvide": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "item": {
                      "type": "string"
                    },
                    "howToObtain": {
                      "type": "string"
                    },
                    "estimatedTimeToObtain": {
                      "type": "string"
                    }
                  }
                }
              },
              "farmerInstructions": {
                "type": "string"
              },
              "responseDeadlineSuggestion": {
                "type": "string"
              }
            }
          },
          "rejectionResponse": {
            "type": "object",
            "description": "Present only when agentAction is 'generate-rejection-response'.",
            "properties": {
              "farmerSupportMessage": {
                "type": "string"
              },
              "rejectionAnalysis": {
                "type": "string"
              },
              "appealLetter": {
                "type": "string"
              },
              "improvementPlan": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "alternativeOptions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "farmerFacingMessagePrimary": {
            "type": "string",
            "description": "ALWAYS populated. The single most important message for the farmer right now. Max 150 words. Matches preferredLanguage. Ends with one clear next action."
          },
          "agentSummary": {
            "type": "string",
            "description": "ALWAYS populated. Internal professional summary (100–150 words). States: action performed, key outputs, whether email will be sent (sendEmail flag), notification type, and recommended next pipeline step."
          }
        }
      }
    }
  ]
}