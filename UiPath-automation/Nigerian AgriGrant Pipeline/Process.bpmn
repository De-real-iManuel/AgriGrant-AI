        <uipath:inputOutput id="categoryScores3" name="categoryScores" type="jsonSchema" elementId="task_eligibility_assessment"><![CDATA[{"type":"object","description":"Scores for each eligibility category (0–100).","properties":{"programFit":{"type":"number","description":"Does farmer match grant target sector, size, location, demographics? 0–100.","minimum":0,"maximum":100},"financialAlignment":{"type":"number","description":"Is funding request within grant limits? Revenue viability? 0–100.","minimum":0,"maximum":100},"documentationReadiness":{"type":"number","description":"Does farmer have the documents this grant requires? 0–100.","minimum":0,"maximum":100},"complianceStatus":{"type":"number","description":"BVN, CAC, cooperative, land docs — meets regulatory requirements? 0–100.","minimum":0,"maximum":100},"projectRelevance":{"type":"number","description":"Does proposed project align with grant objectives? 0–100.","minimum":0,"maximum":100}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="strengths3" name="strengths" type="jsonSchema" subType="string" elementId="task_eligibility_assessment"><![CDATA[{"type":"array","description":"3–5 specific strengths of the farmer's candidacy for this grant.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="riskFactors3" name="riskFactors" type="jsonSchema" subType="string" elementId="task_eligibility_assessment"><![CDATA[{"type":"array","description":"3–5 specific risk factors or gaps in the farmer's application.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="requiredDocuments2" name="requiredDocuments" type="jsonSchema" subType="object" elementId="task_eligibility_assessment"><![CDATA[{"type":"array","description":"Every document this grant requires, with status for each.","items":{"type":"object","properties":{"documentName":{"type":"string","description":"Name of required document (e.g. 'BVN Verification Slip', 'CAC Certificate')."},"farmerHasIt":{"type":"boolean","description":"True if the farmer already has this document based on input data."},"howToObtain":{"type":"string","description":"If farmerHasIt is false, brief instruction on how/where to get it."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="recommendations6" name="recommendations" type="jsonSchema" subType="string" elementId="task_eligibility_assessment"><![CDATA[{"type":"array","description":"2–4 actionable steps the farmer can take to strengthen their application.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="disqualificationReason2" name="disqualificationReason" type="string" elementId="task_eligibility_assessment" />
        <uipath:inputOutput id="grantUrl4" name="grantUrl" type="string" elementId="task_eligibility_assessment" />
        <uipath:inputOutput id="applicationDeadline4" name="applicationDeadline" type="string" elementId="task_eligibility_assessment" />
        <uipath:inputOutput id="maxFundingAmountNgn4" name="maxFundingAmountNGN" type="number" elementId="task_eligibility_assessment" />
        <uipath:inputOutput id="error22" name="Error" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="farmerName10" name="farmerName" type="string" elementId="task_send_congrats" />
        <uipath:inputOutput id="grantName5" name="grantName" type="string" elementId="task_send_congrats" />
        <uipath:inputOutput id="agentAction5" name="agentAction" type="string" elementId="task_send_congrats" />
        <uipath:inputOutput id="currentStatus5" name="currentStatus" type="string" elementId="task_send_congrats" />
        <uipath:inputOutput id="webAppNotification2" name="webAppNotification" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"ALWAYS required. Notification pushed to the farmer's web app dashboard. This is the PRIMARY communication channel for Tier 1 (farmer-facing) alerts.","properties":{"type":{"type":"string","description":"Notification category for the web app UI.","enum":["info","action-required","milestone","warning","chat-response","celebration"]},"title":{"type":"string","description":"Short notification title (max 60 chars)."},"message":{"type":"string","description":"Notification body (max 200 words). Clear, friendly, matches preferredLanguage. NEVER contains technical jargon, error codes, or system details."},"actionRequired":{"type":"boolean","description":"True if the farmer needs to do something. False for informational updates."},"actionUrl":{"type":"string","description":"Optional: Deep link for farmer action (e.g., '/upload-documents', '/chat')."},"timestamp":{"type":"string","description":"ISO timestamp when notification was generated."},"stage":{"type":"string","description":"Current pipeline stage for progress tracker UI.","enum":["discovery","eligibility","documents","proposal","review","submission","monitoring","completed","rejected"]}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="technicalAlert2" name="technicalAlert" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"ALWAYS required. Tier 2 alert for developers/technical team. The farmer NEVER sees this. Used when the system encounters portal issues, API failures, selector failures, or unexpected errors. If no technical issue occurred, set triggered=false and leave other fields empty.","properties":{"triggered":{"type":"boolean","description":"True if a technical issue was detected that requires developer attention. False if everything ran smoothly (normal operation)."},"alertLevel":{"type":"string","description":"Severity of the technical issue. 'low' = minor, auto-recoverable. 'medium' = needs attention within hours. 'high' = blocking farmer journey, needs attention within 30 min. 'critical' = complete system failure, immediate action required.","enum":["none","low","medium","high","critical"]},"alertType":{"type":"string","description":"Category of technical issue for developer dashboard routing.","enum":["none","portal-down","portal-layout-changed","selector-failed","api-error","timeout","authentication-failed","file-upload-failed","unexpected-popup","captcha-detected","network-error","unknown"]},"technicalDetails":{"type":"string","description":"Developer-only technical details. Include: error type, affected component, attempted action, failure point, stack context. This is for the technical dashboard ONLY — farmer never sees this. Empty string if triggered=false."},"farmerFacingMessage":{"type":"string","description":"The friendly, non-technical message shown to the farmer when a technical issue occurs. Must be warm, reassuring, and give no technical details. Example: 'We are doing a quick update on the portal. Your application will resume automatically in a few minutes. Nothing to worry about! 🌱'. Empty string if triggered=false."},"autoRetryInMinutes":{"type":"integer","description":"How many minutes before the system should auto-retry the failed operation. 0 = no auto-retry (requires manual developer intervention). Typical values: 2 for portal issues, 5 for API errors, 0 for critical failures.","minimum":0},"requiresDeveloperAction":{"type":"boolean","description":"True if a developer must manually intervene (e.g., update selectors, fix API keys, resolve portal changes). False if the system can auto-recover."},"suggestedFix":{"type":"string","description":"Optional: Suggested technical fix for the developer (e.g., 'Update selector for #farm-address input', 'Renew API token', 'Portal redesigned — needs full selector remapping'). Empty string if not applicable."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="chatResponse2" name="chatResponse" type="string" elementId="task_send_congrats" />
        <uipath:inputOutput id="emailPayload2" name="emailPayload" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"Email notification structure. ALWAYS present. sendEmail controls delivery.","properties":{"to":{"type":"string","description":"Farmer's email. Empty string if not provided."},"subject":{"type":"string","description":"Email subject personalized with farmer name."},"htmlBody":{"type":"string","description":"HTML email body. Only populated when sendEmail is true."},"plainTextBody":{"type":"string","description":"Plain text version. Only populated when sendEmail is true."},"sendEmail":{"type":"boolean","description":"TRUE = milestone, send email. FALSE = skip email."},"emailType":{"type":"string","enum":["prepare-submission-package","generate-confirmation","set-reminders","track-and-follow-up","handle-additional-info-request","generate-rejection-response","respond-to-farmer-chat"]}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="submissionPackage3" name="submissionPackage" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"Present only when agentAction is 'prepare-submission-package'.","properties":{"readinessAssessment":{"type":"string","enum":["Ready to Submit","Almost Ready — Minor Issues","Not Ready — Critical Items Missing"]},"coverLetter":{"type":"string"},"documentsChecklistVerified":{"type":"array","items":{"type":"object","properties":{"document":{"type":"string"},"status":{"type":"string","enum":["Ready","Missing","Needs Update"]},"note":{"type":"string"}}}},"submissionGuide":{"type":"string"},"criticalWarnings":{"type":"array","items":{"type":"string"}},"submissionTips":{"type":"array","items":{"type":"string"}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="confirmationPackage3" name="confirmationPackage" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"Present only when agentAction is 'generate-confirmation'.","properties":{"congratulatoryMessage":{"type":"string"},"smsMessage":{"type":"string"},"whatsappMessage":{"type":"string"},"submissionSummaryCard":{"type":"object","properties":{"farmerName":{"type":"string"},"grantName":{"type":"string"},"projectTitle":{"type":"string"},"amountRequested":{"type":"string"},"submissionDate":{"type":"string"},"referenceNumber":{"type":"string"},"expectedResponseTime":{"type":"string"},"nextStep":{"type":"string"}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="reminderSchedule3" name="reminderSchedule" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"Present only when agentAction is 'set-reminders'.","properties":{"totalReminders":{"type":"integer"},"reminders":{"type":"array","items":{"type":"object","properties":{"reminderNumber":{"type":"integer"},"triggerEvent":{"type":"string"},"suggestedDate":{"type":"string"},"channel":{"type":"string","enum":["push-notification","SMS","WhatsApp","Email"]},"message":{"type":"string"},"actionRequired":{"type":"string"}}}},"calendarSummary":{"type":"string"}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="trackingAndFollowUp3" name="trackingAndFollowUp" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"Present only when agentAction is 'track-and-follow-up'.","properties":{"statusAssessment":{"type":"string"},"urgencyLevel":{"type":"string","enum":["Routine","Follow-Up Due","Action Required","Urgent"]},"followUpEmailDraft":{"type":"string"},"followUpWhatsappMessage":{"type":"string"},"phoneScriptForFollowUp":{"type":"string"},"nextActions":{"type":"array","items":{"type":"object","properties":{"action":{"type":"string"},"timeline":{"type":"string"},"channel":{"type":"string"}}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="additionalInfoResponse3" name="additionalInfoResponse" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"Present only when agentAction is 'handle-additional-info-request'.","properties":{"acknowledgementLetter":{"type":"string"},"itemsToProvide":{"type":"array","items":{"type":"object","properties":{"item":{"type":"string"},"howToObtain":{"type":"string"},"estimatedTimeToObtain":{"type":"string"}}}},"farmerInstructions":{"type":"string"},"responseDeadlineSuggestion":{"type":"string"}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="rejectionResponse3" name="rejectionResponse" type="jsonSchema" elementId="task_send_congrats"><![CDATA[{"type":"object","description":"Present only when agentAction is 'generate-rejection-response'.","properties":{"farmerSupportMessage":{"type":"string"},"rejectionAnalysis":{"type":"string"},"appealLetter":{"type":"string"},"improvementPlan":{"type":"array","items":{"type":"string"}},"alternativeOptions":{"type":"array","items":{"type":"string"}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="farmerFacingMessagePrimary3" name="farmerFacingMessagePrimary" type="string" elementId="task_send_congrats" />
