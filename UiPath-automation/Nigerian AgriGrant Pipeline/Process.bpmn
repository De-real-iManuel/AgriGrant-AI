        <uipath:inputOutput id="sponsorOrganization2" name="sponsorOrganization" type="string" elementId="task_analyze_docs" />
        <uipath:inputOutput id="grantUrl2" name="grantUrl" type="string" elementId="task_analyze_docs" />
        <uipath:inputOutput id="maxFundingAmountNgn2" name="maxFundingAmountNGN" type="number" elementId="task_analyze_docs" />
