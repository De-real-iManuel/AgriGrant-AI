        <uipath:inputOutput id="eligibilityRiskFactors" name="eligibilityRiskFactors" type="jsonSchema" subType="string" elementId="task_analyze_docs"><![CDATA[{"type":"array","description":"Risk factors from Eligibility Agent, echoed for the Proposal Agent.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="eligibilityRecommendations" name="eligibilityRecommendations" type="jsonSchema" subType="string" elementId="task_analyze_docs"><![CDATA[{"type":"array","description":"Recommendations from Eligibility Agent, echoed for the Proposal Agent.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="analystNarrativeFromEligibility" name="analystNarrativeFromEligibility" type="string" elementId="task_analyze_docs" />
        <uipath:inputOutput id="grantRequirementsCoverage" name="grantRequirementsCoverage" type="jsonSchema" subType="object" elementId="task_analyze_docs"><![CDATA[{"type":"array","description":"For each document listed in requiredDocuments from the Eligibility Agent, indicates whether it was found and validated in the uploaded files.","items":{"type":"object","properties":{"requiredDocument":{"type":"string","description":"Name of the document required by the grant (from Eligibility Agent's requiredDocuments list)."},"status":{"type":"string","description":"Coverage status for this requirement.","enum":["Provided & Valid","Provided — Needs Review","Missing","Not Applicable"]},"notes":{"type":"string","description":"Optional: brief note on why status was assigned (e.g. 'BVN confirmation slip found and matches farmer name')."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="rpaAttachmentRequired" name="rpaAttachmentRequired" type="boolean" elementId="task_analyze_docs" />
        <uipath:inputOutput id="documentsToAttachForRpa" name="documentsToAttachForRPA" type="jsonSchema" subType="object" elementId="task_analyze_docs"><![CDATA[{"type":"array","description":"List of specific documents the RPA Portal Submission Robot must attach during form submission. Empty array if rpaAttachmentRequired is false. Each item names the document type and its file reference.","items":{"type":"object","properties":{"documentType":{"type":"string","description":"Type of document (e.g. 'CAC Certificate', 'Bank Statement', 'C of O', 'Passport Photograph')."},"fileName":{"type":"string","description":"Original file name from the uploaded documents array."},"attachmentNotes":{"type":"string","description":"Optional: notes for the RPA robot (e.g. 'Attach to Section 4 — Supporting Documents', 'Required file format: PDF only')."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="documentBoostInsights" name="documentBoostInsights" type="jsonSchema" subType="string" elementId="task_analyze_docs"><![CDATA[{"type":"array","description":"Key details discovered in the documents that strengthen the farmer's grant application case. These are passed to the Proposal Agent to weave into the proposal narrative (e.g. 'Bank statement confirms consistent monthly inflow of NGN 150,000 — demonstrates financial stability', 'C of O confirms 4.2 ha ownership — satisfies smallholder land requirement for NIRSAL', 'Cooperative certificate dated 2021 — proves 5 years active membership').","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="nameConsistencyCheck2" name="nameConsistencyCheck" type="string" elementId="task_analyze_docs" />
        <uipath:inputOutput id="documentResults2" name="documentResults" type="jsonSchema" subType="object" elementId="task_analyze_docs"><![CDATA[{"type":"array","description":"Per-document extraction results. One object per uploaded document — never skip one.","items":{"type":"object","properties":{"documentIndex":{"type":"integer","description":"Zero-based index matching position in the input documents array."},"fileName":{"type":"string","description":"Original file name of the uploaded document."},"detectedDocumentType":{"type":"string","description":"Document type as detected (e.g. 'NIN Slip', 'C of O', 'CAC Registration', 'Bank Statement', 'Cooperative Certificate')."},"extractedFields":{"type":"object","description":"Key-value pairs of all extracted fields. Keys in lowercase snake_case (e.g. full_name, nin_number, land_area_hectares).","additionalProperties":{"type":"string"}},"validationStatus":{"type":"string","description":"Authenticity: Valid / Likely Valid / Suspicious / Invalid / Unverifiable.","enum":["Valid","Likely Valid","Suspicious","Invalid","Unverifiable"]},"flags":{"type":"array","description":"Specific anomalies detected. Empty array if none.","items":{"type":"string"}},"documentSummary":{"type":"string","description":"1–2 sentence plain-English summary of what this document confirms about the farmer."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="consolidatedFarmerProfile2" name="consolidatedFarmerProfile" type="jsonSchema" elementId="task_analyze_docs"><![CDATA[{"type":"object","description":"Unified profile assembled from all documents — most reliable version of each data point.","properties":{"fullName":{"type":"string","description":"Best confirmed full name across all documents."},"dateOfBirth":{"type":"string","description":"Date of birth in ISO format (YYYY-MM-DD) if found."},"nationalId":{"type":"string","description":"NIN or other national ID number if found."},"address":{"type":"string","description":"Most complete address found across documents."},"stateOfOrigin":{"type":"string","description":"Nigerian state of origin if found."},"lgaOfOrigin":{"type":"string","description":"Local Government Area if found."},"landHoldings":{"type":"array","description":"Confirmed land parcels with size and location.","items":{"type":"string"}},"businessRegistration":{"type":"string","description":"CAC registration number and business name if found."},"bankDetails":{"type":"string","description":"Bank name, account name, last 4 digits if found."},"farmingActivities":{"type":"array","description":"Confirmed farming activities or crops from cooperative or certification documents.","items":{"type":"string"}},"activeLoansOrObligations":{"type":"string","description":"Any active loans or CBN/NIRSAL obligations found in documents."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="crossDocumentInconsistencies2" name="crossDocumentInconsistencies" type="jsonSchema" subType="string" elementId="task_analyze_docs"><![CDATA[{"type":"array","description":"Contradictions found when comparing data across documents. Empty array if none.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="missingCriticalDocuments2" name="missingCriticalDocuments" type="jsonSchema" subType="string" elementId="task_analyze_docs"><![CDATA[{"type":"array","description":"Documents not uploaded that are required for the grant. Cross-referenced against requiredDocuments from Eligibility Agent. Empty array if all provided.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
