        <uipath:inputOutput id="categoryScores2" name="categoryScores" type="jsonSchema" elementId="Activity_Mvo0u5"><![CDATA[{"type":"object","description":"Scores for each eligibility category (0–100).","properties":{"programFit":{"type":"number","description":"Does farmer match grant target sector, size, location, demographics? 0–100.","minimum":0,"maximum":100},"financialAlignment":{"type":"number","description":"Is funding request within grant limits? Revenue viability? 0–100.","minimum":0,"maximum":100},"documentationReadiness":{"type":"number","description":"Does farmer have the documents this grant requires? 0–100.","minimum":0,"maximum":100},"complianceStatus":{"type":"number","description":"BVN, CAC, cooperative, land docs — meets regulatory requirements? 0–100.","minimum":0,"maximum":100},"projectRelevance":{"type":"number","description":"Does proposed project align with grant objectives? 0–100.","minimum":0,"maximum":100}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="strengths2" name="strengths" type="jsonSchema" subType="string" elementId="Activity_Mvo0u5"><![CDATA[{"type":"array","description":"3–5 specific strengths of the farmer's candidacy for this grant.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="riskFactors2" name="riskFactors" type="jsonSchema" subType="string" elementId="Activity_Mvo0u5"><![CDATA[{"type":"array","description":"3–5 specific risk factors or gaps in the farmer's application.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="requiredDocuments" name="requiredDocuments" type="jsonSchema" subType="object" elementId="Activity_Mvo0u5"><![CDATA[{"type":"array","description":"Every document this grant requires, with status for each.","items":{"type":"object","properties":{"documentName":{"type":"string","description":"Name of required document (e.g. 'BVN Verification Slip', 'CAC Certificate')."},"farmerHasIt":{"type":"boolean","description":"True if the farmer already has this document based on input data."},"howToObtain":{"type":"string","description":"If farmerHasIt is false, brief instruction on how/where to get it."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="recommendations3" name="recommendations" type="jsonSchema" subType="string" elementId="Activity_Mvo0u5"><![CDATA[{"type":"array","description":"2–4 actionable steps the farmer can take to strengthen their application.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
