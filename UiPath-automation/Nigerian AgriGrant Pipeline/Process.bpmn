        <uipath:inputOutput id="matchedGrants2" name="matchedGrants" type="jsonSchema" subType="object" elementId="task_grant_discovery"><![CDATA[{"type":"array","description":"Ranked list of matched FREE grant opportunities sorted by matchScore descending. Every entry must be a free grant — no loans, no credit facilities, no repayment-based programs.","items":{"type":"object","properties":{"grantName":{"type":"string","description":"Official name of the FREE grant program. Must be a grant — never a loan."},"grantingOrganization":{"type":"string","description":"Full name of the organization providing the FREE grant."},"grantCategory":{"type":"string","description":"Category of grant source.","enum":["federal","state","NGO","international","development-bank","private"]},"fundingBody":{"type":"string","description":"Specific body or programme window providing the free grant."},"description":{"type":"string","description":"2 to 3 sentence description of what the FREE grant funds, its objectives, and target beneficiaries."},"fundingAmountRange":{"type":"string","description":"Estimated FREE grant funding range in NGN or USD."},"currency":{"type":"string","description":"Primary currency of the grant disbursement.","enum":["NGN","USD","EUR","GBP","Mixed"]},"matchScore":{"type":"integer","description":"Match score 0 to 100 indicating how well the FREE grant fits this farmer's profile.","minimum":0,"maximum":100},"matchReason":{"type":"string","description":"Specific explanation of why this FREE grant matches the farmer."},"eligibilityCriteria":{"type":"string","description":"Key eligibility requirements the farmer must meet for this FREE grant."},"requiredDocuments":{"type":"array","description":"List of key documents typically required to apply for this grant.","items":{"type":"string"}},"applicationProcess":{"type":"string","description":"Brief description of how to apply for this FREE grant."},"applicationDeadline":{"type":"string","description":"Application deadline or cycle."},"geographicScope":{"type":"string","description":"Geographic coverage of the grant."},"applicationUrl":{"type":"string","description":"Official URL for the grant page, portal, or organization homepage."},"contactInformation":{"type":"string","description":"Relevant contact details if available."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="availableGrants" name="availableGrants" type="jsonSchema" subType="object" elementId="Process_1"><![CDATA[{"type":"array","description":"Available grants for farmer selection, mirrored from Discovery Agent matchedGrants output.","items":{"type":"object","properties":{"grantName":{"type":"string"},"grantingOrganization":{"type":"string"},"grantCategory":{"type":"string","enum":["federal","state","NGO","international","development-bank","private"]},"fundingBody":{"type":"string"},"description":{"type":"string"},"fundingAmountRange":{"type":"string"},"currency":{"type":"string","enum":["NGN","USD","EUR","GBP","Mixed"]},"matchScore":{"type":"integer","minimum":0,"maximum":100},"matchReason":{"type":"string"},"eligibilityCriteria":{"type":"string"},"requiredDocuments":{"type":"array","items":{"type":"string"}},"applicationProcess":{"type":"string"},"applicationDeadline":{"type":"string"},"geographicScope":{"type":"string"},"applicationUrl":{"type":"string"},"contactInformation":{"type":"string"}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="profileGaps2" name="profileGaps" type="jsonSchema" subType="string" elementId="task_grant_discovery"><![CDATA[{"type":"array","description":"Specific profile gaps or missing registrations limiting the farmer's access to FREE grants.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
