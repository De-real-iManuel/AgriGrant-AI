    <bpmn:sequenceFlow id="flow_check_docs_to_gw" sourceRef="task_check_docs_required" targetRef="gw_docs_required" />
    <bpmn:sequenceFlow id="flow_docs_required_yes" name="Yes" sourceRef="gw_docs_required" targetRef="task_identify_doc_types">
