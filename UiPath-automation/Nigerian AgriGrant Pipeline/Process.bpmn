        <uipath:inputOutput id="coverPage4" name="coverPage" type="jsonSchema" elementId="task_compose_proposal"><![CDATA[{"type":"object","description":"Structured cover page metadata. Populated when documentType is 'full_proposal' or 'both'. Null object when documentType is 'application_letter'.","properties":{"projectTitle":{"type":"string","description":"Full project title as it appears on the cover page."},"submittedBy":{"type":"string","description":"Applicant or organization name."},"submittedTo":{"type":"string","description":"Granting organization name and department."},"projectLocation":{"type":"string","description":"State and LGA of the project."},"projectDuration":{"type":"string","description":"Project duration in readable format (e.g., '18 months: January 2026 – June 2027')."},"totalFundingRequested":{"type":"string","description":"Amount in NGN formatted with commas (e.g., 'NGN 5,000,000')."},"submissionDate":{"type":"string","description":"Submission date in format 'Month YYYY'."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
