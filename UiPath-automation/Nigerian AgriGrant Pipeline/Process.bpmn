        <uipath:inputOutput id="documentResults3" name="documentResults" type="jsonSchema" subType="object" elementId="task_check_docs_required"><![CDATA[{"type":"array","description":"Per-document extraction results. One object per uploaded document — never skip one.","items":{"type":"object","properties":{"documentIndex":{"type":"integer","description":"Zero-based index matching position in the input documents array."},"fileName":{"type":"string","description":"Original file name of the uploaded document."},"detectedDocumentType":{"type":"string","description":"Document type as detected (e.g. 'NIN Slip', 'C of O', 'CAC Registration', 'Bank Statement', 'Cooperative Certificate')."},"extractedFields":{"type":"object","description":"Key-value pairs of all extracted fields. Keys in lowercase snake_case (e.g. full_name, nin_number, land_area_hectares).","additionalProperties":{"type":"string"}},"validationStatus":{"type":"string","description":"Authenticity: Valid / Likely Valid / Suspicious / Invalid / Unverifiable.","enum":["Valid","Likely Valid","Suspicious","Invalid","Unverifiable"]},"flags":{"type":"array","description":"Specific anomalies detected. Empty array if none.","items":{"type":"string"}},"documentSummary":{"type":"string","description":"1–2 sentence plain-English summary of what this document confirms about the farmer."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="consolidatedFarmerProfile3" name="consolidatedFarmerProfile" type="jsonSchema" elementId="task_check_docs_required"><![CDATA[{"type":"object","description":"Unified profile assembled from all documents — most reliable version of each data point.","properties":{"fullName":{"type":"string","description":"Best confirmed full name across all documents."},"dateOfBirth":{"type":"string","description":"Date of birth in ISO format (YYYY-MM-DD) if found."},"nationalId":{"type":"string","description":"NIN or other national ID number if found."},"address":{"type":"string","description":"Most complete address found across documents."},"stateOfOrigin":{"type":"string","description":"Nigerian state of origin if found."},"lgaOfOrigin":{"type":"string","description":"Local Government Area if found."},"landHoldings":{"type":"array","description":"Confirmed land parcels with size and location.","items":{"type":"string"}},"businessRegistration":{"type":"string","description":"CAC registration number and business name if found."},"bankDetails":{"type":"string","description":"Bank name, account name, last 4 digits if found."},"farmingActivities":{"type":"array","description":"Confirmed farming activities or crops from cooperative or certification documents.","items":{"type":"string"}},"activeLoansOrObligations":{"type":"string","description":"Any active loans or CBN/NIRSAL obligations found in documents."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="crossDocumentInconsistencies3" name="crossDocumentInconsistencies" type="jsonSchema" subType="string" elementId="task_check_docs_required"><![CDATA[{"type":"array","description":"Contradictions found when comparing data across documents. Empty array if none.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="missingCriticalDocuments3" name="missingCriticalDocuments" type="jsonSchema" subType="string" elementId="task_check_docs_required"><![CDATA[{"type":"array","description":"Documents not uploaded that are required for the grant. Cross-referenced against requiredDocuments from Eligibility Agent. Empty array if all provided.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="overallDocumentScore3" name="overallDocumentScore" type="number" elementId="task_check_docs_required" />
        <uipath:inputOutput id="documentVerdict3" name="documentVerdict" type="string" elementId="task_check_docs_required" />
        <uipath:inputOutput id="analystNotes3" name="analystNotes" type="string" elementId="task_check_docs_required" />
        <uipath:inputOutput id="recommendations5" name="recommendations" type="jsonSchema" subType="string" elementId="task_check_docs_required"><![CDATA[{"type":"array","description":"Concrete actions for the farmer to resolve flags, fill gaps, or strengthen their document package (e.g. 'Resubmit NIN slip with clearer scan', 'Provide recent bank statement stamped by bank manager').","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error15" name="Error" type="jsonSchema" elementId="task_collect_grant_details"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="applicantName3" name="applicantName" type="string" elementId="task_collect_grant_details" />
