<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" exporter="UiPath Studio Web (https://uipath.com)" exporterVersion="e22c34e4">
  <bpmn:process id="Process_1" name="Process">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:inputOutput id="error" name="Error" type="jsonSchema" elementId="Activity_UG1NME"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="farmerName" name="farmerName" type="string" elementId="Activity_UG1NME" />
        <uipath:inputOutput id="stateOfResidence" name="stateOfResidence" type="string" elementId="Activity_UG1NME" />
        <uipath:inputOutput id="totalMatchesFound" name="totalMatchesFound" type="integer" elementId="Activity_UG1NME" />
        <uipath:inputOutput id="matchedGrants" name="matchedGrants" type="jsonSchema" subType="object" elementId="Activity_UG1NME"><![CDATA[{"type":"array","description":"Ranked list of matched grant opportunities sorted by matchScore descending. Only include grants with matchScore >= 40.","items":{"type":"object","properties":{"grantName":{"type":"string","description":"Official name of the grant, loan scheme, or funding program (e.g., 'CBN Anchor Borrowers Programme', 'NIRSAL AGSMEIS', 'World Bank APPEALS Project')."},"grantingOrganization":{"type":"string","description":"Full name of the organization administering the grant (e.g., 'Central Bank of Nigeria', 'Bank of Agriculture', 'FMARD', 'FAO Nigeria', 'World Bank')."},"grantCategory":{"type":"string","description":"Category of grant source: 'federal' = Nigerian federal agencies (CBN, BOA, FMARD, NIRSAL, NASC). 'state' = state government programs. 'NGO' = national or international NGOs (GIZ, ActionAid, etc.). 'international' = UN agencies and bilateral donors (FAO, IFAD, USAID). 'development-bank' = AfDB, World Bank, ECOWAS Bank. 'private' = private sector CSR or foundations.","enum":["federal","state","NGO","international","development-bank","private"]},"fundingBody":{"type":"string","description":"Specific body or programme window (e.g., 'CBN Development Finance Department', 'NIRSAL Plc', 'BOA Federal', 'FMARD APPEALS', 'IFAD VCDP', 'World Bank IDA')."},"description":{"type":"string","description":"2 to 3 sentence description of what the grant funds, its objectives, and target beneficiaries in the Nigerian agricultural context."},"fundingAmountRange":{"type":"string","description":"Estimated funding range in NGN or USD (e.g., 'NGN 500,000 to NGN 5,000,000', 'Up to NGN 50,000,000', 'USD 10,000 to USD 100,000'). Use 'Varies by state or cluster' or 'Check with issuing body' if not specified."},"currency":{"type":"string","description":"Primary currency of the grant disbursement.","enum":["NGN","USD","EUR","GBP","Mixed"]},"matchScore":{"type":"integer","description":"Match score 0 to 100 indicating how well the grant fits this farmer's profile. Scored on: farm type match (+25), location eligibility (+20), demographic fit (+20), funding purpose alignment (+25), registration and documentation readiness (+10).","minimum":0,"maximum":100},"matchReason":{"type":"string","description":"Specific explanation of why this grant matches the farmer (e.g., 'Matches: smallholder cassava farmer in Benue State, cooperative member, funding purpose aligns with input procurement under CBN Anchor Borrowers value chain')."},"eligibilityCriteria":{"type":"string","description":"Key eligibility requirements the farmer must meet (e.g., 'Nigerian citizen, registered cooperative member, smallholder farmer, minimum 1 hectare under cultivation, valid BVN, no CBN loan default')."},"requiredDocuments":{"type":"array","description":"List of key documents typically required to apply (e.g., 'Valid NIN or Voter Card', 'CAC registration certificate', 'Bank account with BVN', 'Land document or C of O', 'Passport photograph').","items":{"type":"string"}},"applicationProcess":{"type":"string","description":"Brief description of how to apply (e.g., 'Apply through nearest BOA branch', 'Submit via NIRSAL online portal', 'Apply through state FMARD office', 'Apply via cooperative society to CBN ACGSF desk')."},"applicationDeadline":{"type":"string","description":"Application deadline or cycle (e.g., 'Rolling - apply any time', 'Annual - Q1 cycle', 'Closed - watch for next window'). Never guess a date. Use 'Check official source' if unknown."},"geographicScope":{"type":"string","description":"Geographic coverage of the grant (e.g., 'Nationwide', 'Benue, Kogi and Niger States only', 'North-West geopolitical zone', 'FCT and Ogun State pilot')."},"applicationUrl":{"type":"string","description":"Official URL for the grant page, portal, or organization homepage. Use empty string if not found. Never fabricate a URL."},"contactInformation":{"type":"string","description":"Relevant contact details if available (e.g., 'NIRSAL Plc: info@nirsal.com', 'BOA nearest state branch', 'FMARD Abuja: info@fmard.gov.ng'). Use empty string if not available."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="profileGaps" name="profileGaps" type="jsonSchema" subType="string" elementId="Activity_UG1NME"><![CDATA[{"type":"array","description":"Specific profile gaps or missing registrations limiting the farmer's grant options (e.g., 'No CAC registration - excludes from most federal programs', 'Not a cooperative member - eliminates CBN Anchor Borrowers eligibility', 'No land document - restricts BOA land-linked programs').","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="topRecommendation" name="topRecommendation" type="string" elementId="Activity_UG1NME" />
        <uipath:inputOutput id="summary" name="summary" type="string" elementId="Activity_UG1NME" />
        <uipath:inputOutput id="disclaimer" name="disclaimer" type="string" elementId="Activity_UG1NME" />
        <uipath:inputOutput id="error2" name="Error" type="jsonSchema" elementId="Activity_Ot7uet"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="applicantName" name="applicantName" type="string" elementId="Activity_Ot7uet" />
        <uipath:inputOutput id="farmLocation" name="farmLocation" type="string" elementId="Activity_Ot7uet" />
        <uipath:inputOutput id="targetGrant" name="targetGrant" type="string" elementId="Activity_Ot7uet" />
        <uipath:inputOutput id="overallEligibilityScore" name="overallEligibilityScore" type="number" elementId="Activity_Ot7uet" />
        <uipath:inputOutput id="eligibilityVerdict" name="eligibilityVerdict" type="string" elementId="Activity_Ot7uet" />
        <uipath:inputOutput id="categoryScores" name="categoryScores" type="jsonSchema" elementId="Activity_Ot7uet"><![CDATA[{"type":"object","description":"Breakdown of scores per evaluation category, each from 0 to 100. Weighted average produces the overallEligibilityScore.","properties":{"farmProfileAlignment":{"type":"number","description":"Score (0–100) for how well the farm type, size in hectares, Nigerian state location, crop or livestock types, and years of operation align with the grant's eligibility criteria."},"financialEligibility":{"type":"number","description":"Score (0–100) assessing whether the annual revenue in NGN and requested funding amount in NGN fall within the grant's financial thresholds (e.g., NIRSAL AGSMEIS max NGN 10M, CBN CACS minimum NGN 100M turnover)."},"projectRelevance":{"type":"number","description":"Score (0–100) for how clearly the proposed project aligns with the grant's stated objectives, eligible value chains, and permissible uses of funds."},"documentationReadiness":{"type":"number","description":"Score (0–100) for the completeness and quality of Nigerian grant documents: NIN, CAC certificate, BVN confirmation, bank statements, C of O or land document, cooperative letter, passport photograph, and farm business plan."},"complianceAndPlanning":{"type":"number","description":"Score (0–100) based on: CAC registration status, BVN linkage, cooperative membership, absence of CBN/BOA loan defaults (CRMS clean record), and existence of a documented farm business plan or cooperative development plan."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="nigerianComplianceFlags" name="nigerianComplianceFlags" type="jsonSchema" elementId="Activity_Ot7uet"><![CDATA[{"type":"object","description":"Critical Nigerian-specific compliance checks that directly affect grant eligibility. Each flag is a pass/fail/warning indicator.","properties":{"bvnStatus":{"type":"string","enum":["Pass","Fail","Unknown"],"description":"Whether the farmer has a valid BVN linked to an active bank account. 'Fail' is a disqualifying factor for CBN, NIRSAL, and BOA programs."},"cacStatus":{"type":"string","enum":["Registered","Not Registered","Unknown"],"description":"Whether the farmer has a valid CAC registration (BN or RC number). Required for NIRSAL AGSMEIS, CBN CACS, and most federal programs."},"cooperativeMembership":{"type":"string","enum":["Active Member","Not a Member","Unknown"],"description":"Whether the farmer is an active registered cooperative member. Hard requirement for CBN Anchor Borrowers Programme."},"landDocumentStatus":{"type":"string","enum":["Valid Document Held","No Document","Unknown"],"description":"Whether the farmer holds a C of O, R of O, Survey Plan, or formal tenancy agreement. Affects BOA and land-linked grant eligibility."},"loanDefaultRisk":{"type":"string","enum":["No Known Default","Default Flagged — High Risk","Unknown"],"description":"Whether a CBN/BOA loan default exists in CRMS. 'Default Flagged' is a disqualifying factor for all CBN-backed and NIRSAL programs."},"smallholderClassification":{"type":"string","enum":["Smallholder (under 5 ha)","Medium-Scale (5–20 ha)","Large-Scale (above 20 ha)","Unknown"],"description":"Farm size classification in hectares. Determines eligibility for smallholder-specific programs (CBN ABP, NIRSAL, IFAD, FAO)."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="strengths" name="strengths" type="jsonSchema" subType="string" elementId="Activity_Ot7uet"><![CDATA[{"type":"array","items":{"type":"string"},"description":"Specific factors that strongly support the Nigerian grant application. Each item must reference a concrete fact from the input (e.g., 'Active CAC registration strengthens eligibility for NIRSAL AGSMEIS window', 'Cooperative membership satisfies CBN Anchor Borrowers hard requirement').","$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="riskFactors" name="riskFactors" type="jsonSchema" subType="string" elementId="Activity_Ot7uet"><![CDATA[{"type":"array","items":{"type":"string"},"description":"Identified risks, red flags, or weak areas that may jeopardize eligibility or reduce the score (e.g., 'No BVN on record — disqualifies from all CBN-backed programs', 'Requested NGN 15M exceeds NIRSAL AGSMEIS maximum of NGN 10M', 'Farm size of 12 ha exceeds smallholder threshold for IFAD VCDP').","$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="missingItems" name="missingItems" type="jsonSchema" subType="string" elementId="Activity_Ot7uet"><![CDATA[{"type":"array","items":{"type":"string"},"description":"Specific documents, registrations, or conditions that are absent but required by the grant. Each item must describe exactly what is missing and why it matters for this Nigerian grant program (e.g., 'CAC registration missing — mandatory for NIRSAL AGSMEIS; obtain at any CAC office or via CAC online portal', 'No cooperative membership letter — required for CBN Anchor Borrowers Programme application through the cooperative desk').","$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="analystNarrative" name="analystNarrative" type="string" elementId="Activity_Ot7uet" />
        <uipath:inputOutput id="recommendations" name="recommendations" type="jsonSchema" subType="string" elementId="Activity_Ot7uet"><![CDATA[{"type":"array","items":{"type":"string"},"description":"Actionable, Nigeria-specific steps the farmer can take to improve eligibility or strengthen the application. Be concrete and practical (e.g., 'Register a business name with CAC online at cac.gov.ng — costs NGN 10,000–25,000 and takes 5–10 business days', 'Join a registered cooperative society in your LGA to qualify for CBN Anchor Borrowers Programme', 'Visit your bank branch to confirm BVN is linked to your active account and request a BVN confirmation slip').","$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="alternativeGrants" name="alternativeGrants" type="string" elementId="Activity_Ot7uet" />
        <uipath:inputOutput id="error3" name="Error" type="jsonSchema" elementId="Activity_pGNFdn"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="farmerName2" name="farmerName" type="string" elementId="Activity_pGNFdn" />
        <uipath:inputOutput id="nameConsistencyCheck" name="nameConsistencyCheck" type="string" elementId="Activity_pGNFdn" />
        <uipath:inputOutput id="documentResults" name="documentResults" type="jsonSchema" subType="object" elementId="Activity_pGNFdn"><![CDATA[{"type":"array","description":"Per-document extraction results. One object per uploaded document.","items":{"type":"object","properties":{"documentIndex":{"type":"integer","description":"Zero-based index matching the position of the document in the input `documents` array."},"fileName":{"type":"string","description":"Original file name of the uploaded document."},"detectedDocumentType":{"type":"string","description":"Document type as detected by the agent (e.g., 'NIN Slip', 'Certificate of Occupancy', 'CAC Registration', 'Bank Statement', 'NIRSAL Loan Agreement', 'Farm Cooperative Certificate', 'Voter Card', 'International Passport', 'Survey Plan', 'NAFDAC Permit', 'Unknown')."},"extractedFields":{"type":"object","description":"Key-value pairs of all extracted fields from this document. Field names depend on document type. Examples: fullName, dateOfBirth, ninNumber, issuingAuthority, plotNumber, landArea, registrationNumber, accountName, bankName, statementPeriod, balance, loanAmount, cooperativeName, etc.","additionalProperties":{"type":"string"}},"validationStatus":{"type":"string","description":"Authenticity assessment of this document. 'Valid' = all expected fields present and internally consistent. 'Likely Valid' = minor issues but appears genuine. 'Suspicious' = notable anomalies flagged. 'Invalid' = clear forgery indicators or critical missing elements. 'Unverifiable' = cannot determine from content alone.","enum":["Valid","Likely Valid","Suspicious","Invalid","Unverifiable"]},"flags":{"type":"array","description":"Specific anomalies, inconsistencies, or concerns detected in this document (e.g., 'Date of issue is in the future', 'Name spelling differs from other documents', 'Missing official stamp', 'Blurred or unreadable section'). Empty array if no flags.","items":{"type":"string"}},"documentSummary":{"type":"string","description":"1–2 sentence plain-English summary of what this document confirms about the farmer."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="consolidatedFarmerProfile" name="consolidatedFarmerProfile" type="jsonSchema" elementId="Activity_pGNFdn"><![CDATA[{"type":"object","description":"A unified profile assembled from all documents combined. Contains the most reliable version of key data points.","properties":{"fullName":{"type":"string","description":"Best confirmed full name across all documents."},"dateOfBirth":{"type":"string","description":"Date of birth in ISO format (YYYY-MM-DD) if found."},"nationalId":{"type":"string","description":"NIN or other national ID number if found."},"address":{"type":"string","description":"Most complete address found across documents."},"stateOfOrigin":{"type":"string","description":"Nigerian state of origin if found."},"lgaOfOrigin":{"type":"string","description":"Local Government Area if found."},"landHoldings":{"type":"array","description":"List of confirmed land parcels with size and location (e.g., '2.5 hectares at Plot 4, Block B, Abuja FCT').","items":{"type":"string"}},"businessRegistration":{"type":"string","description":"CAC registration number and business name if found."},"bankDetails":{"type":"string","description":"Bank name, account name, and last 4 digits of account if found."},"farmingActivities":{"type":"array","description":"Confirmed farming activities or crops from cooperative or certification documents.","items":{"type":"string"}},"activeLoansOrObligations":{"type":"string","description":"Any active loans, CBN/NIRSAL obligations, or financial commitments found in documents."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="crossDocumentInconsistencies" name="crossDocumentInconsistencies" type="jsonSchema" subType="string" elementId="Activity_pGNFdn"><![CDATA[{"type":"array","description":"Specific contradictions found when comparing data across multiple documents (e.g., 'Date of birth is 1985-03-10 on NIN but 1985-07-10 on passport', 'Land area is 5 hectares on C of O but 2 hectares on survey plan'). Empty array if none found.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="missingCriticalDocuments" name="missingCriticalDocuments" type="jsonSchema" subType="string" elementId="Activity_pGNFdn"><![CDATA[{"type":"array","description":"Important document types not found in the uploaded set that are typically required for Nigerian agricultural grant applications (e.g., 'No valid government-issued ID found', 'No land ownership document provided', 'No bank statement found'). Empty array if all critical documents are present.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="overallDocumentScore" name="overallDocumentScore" type="number" elementId="Activity_pGNFdn" />
        <uipath:inputOutput id="documentVerdict" name="documentVerdict" type="string" elementId="Activity_pGNFdn" />
        <uipath:inputOutput id="analystNotes" name="analystNotes" type="string" elementId="Activity_pGNFdn" />
        <uipath:inputOutput id="recommendations2" name="recommendations" type="jsonSchema" subType="string" elementId="Activity_pGNFdn"><![CDATA[{"type":"array","description":"Concrete actions the farmer should take to resolve flags, fill gaps, or strengthen their document package (e.g., 'Resubmit NIN slip with clearer scan', 'Provide a recent utility bill to confirm residential address', 'Obtain updated CAC status report').","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error5" name="Error" type="jsonSchema" elementId="Activity_MoZND9"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="comment" name="Comment" type="string" elementId="Activity_MoZND9" />
        <uipath:inputOutput id="action" name="Action" type="string" elementId="Activity_MoZND9" />
        <uipath:inputOutput id="hitlTask" name="hitlTask" type="jsonSchema" elementId="Activity_MoZND9"><![CDATA[{"type":"object","displayName":"All Task Properties","properties":{"Id":{"type":"integer","description":"Task identifier"},"Key":{"type":"string","description":"Unique task identifier (UUID)"},"Title":{"type":"string","description":"Task title"},"Status":{"type":"string","description":"Task status: Unassigned, Pending, or Completed"},"Action":{"type":"string","description":"Action taken on the task"},"ActionLabel":{"type":"string","description":"Action display label"},"Priority":{"type":"string","description":"Task priority: Low, Medium, High, or Critical"},"Type":{"type":"string","description":"Task type (e.g. FormTask, AppTask, QuickFormTask)"},"Data":{"type":"object","description":"Task form field values"},"CompletedByUser":{"type":"object","description":"User who completed the task","properties":{"Id":{"type":"integer"},"Name":{"type":"string"},"Surname":{"type":"string"},"UserName":{"type":"string"},"EmailAddress":{"type":"string"},"DisplayName":{"type":"string"},"Type":{"type":"string","description":"User, Robot, DirectoryUser, DirectoryGroup, DirectoryRobot, or DirectoryExternalApplication"},"AuthenticationSource":{"type":"string"}}},"AssignedToUser":{"type":"object","description":"User currently assigned to the task","properties":{"Id":{"type":"integer"},"Name":{"type":"string"},"Surname":{"type":"string"},"UserName":{"type":"string"},"EmailAddress":{"type":"string"},"DisplayName":{"type":"string"},"Type":{"type":"string","description":"User, Robot, DirectoryUser, DirectoryGroup, DirectoryRobot, or DirectoryExternalApplication"},"AuthenticationSource":{"type":"string"}}},"AssignedToUserId":{"type":"integer","description":"ID of the assigned user"},"TaskAssignmentCriteria":{"type":"string","description":"Assignment criteria: SingleUser, Workload, AllUsers, RoundRobin, or Hierarchy"},"TaskAssignees":{"type":"array","description":"List of users assigned to the task","items":{"type":"object","properties":{"Id":{"type":"integer"},"Name":{"type":"string"},"Surname":{"type":"string"},"UserName":{"type":"string"},"EmailAddress":{"type":"string"},"DisplayName":{"type":"string"},"Type":{"type":"string","description":"User, Robot, DirectoryUser, DirectoryGroup, DirectoryRobot, or DirectoryExternalApplication"},"AuthenticationSource":{"type":"string"}}}},"CompletionTime":{"type":"string","description":"Task completion timestamp"},"CreationTime":{"type":"string","description":"Task creation timestamp"},"LastModificationTime":{"type":"string","description":"Last modification timestamp"},"LastAssignedTime":{"type":"string","description":"Last assignment timestamp"},"OrganizationUnitId":{"type":"integer","description":"Folder/organization unit ID"},"OrganizationUnitFullyQualifiedName":{"type":"string","description":"Fully qualified folder name"},"ParentOperationId":{"type":"string","description":"Operation ID that created this task"},"CreatorJobKey":{"type":"string","description":"Key of the job that created this task (UUID)"},"ExternalTag":{"type":"string","description":"External system identifier"},"ProcessingTime":{"type":"integer","description":"Time spent in assigned state"},"WaitJobState":{"type":"string","description":"State of the waiting job"},"WaitJobKey":{"type":"string","description":"Key of the waiting job (UUID)"},"TaskSchemaKey":{"type":"string","description":"Schema key for QuickFormTask (UUID)"},"IsDeleted":{"type":"boolean"},"IsCurrentUserInAllUserAssignedGroup":{"type":"boolean"},"CreatorUserId":{"type":"integer","description":"ID of the user who created the task"},"LastModifierUserId":{"type":"integer","description":"ID of the last user to modify the task"},"DeleterUserId":{"type":"integer"},"DeletionTime":{"type":"string"},"Tags":{"type":"array","description":"Tags associated to the task","items":{"type":"object","properties":{"Name":{"type":"string"},"DisplayName":{"type":"string"},"Value":{"type":"string"},"DisplayValue":{"type":"string"}}}},"TaskDefinitionPropertiesId":{"type":"integer","description":"Task definition properties ID"},"AppTasksMetadata":{"type":"object","description":"App task metadata","properties":{"Id":{"type":"integer"},"AppId":{"type":"string","description":"Associated App ID"},"AppVersion":{"type":"integer","description":"Associated App version"},"AppProcessKey":{"type":"string","description":"App process key (UUID)"},"FolderKey":{"type":"string","description":"Folder key (UUID)"},"Runtime":{"type":"string","description":"Serverless or Unattended"},"AppType":{"type":"string","description":"Custom or Dynamic"},"CreationTime":{"type":"string"},"CreatorUserId":{"type":"integer"},"CreatorUserKey":{"type":"string","description":"Creator user key (UUID)"}}},"TaskSlaDetails":{"type":"array","description":"Task SLA details","items":{"type":"object","properties":{"ExpiryTime":{"type":"string","description":"SLA expiry timestamp"},"StartCriteria":{"type":"string","description":"TaskCreated, TaskAssigned, or TaskCompleted"},"EndCriteria":{"type":"string","description":"TaskCreated, TaskAssigned, or TaskCompleted"},"Status":{"type":"string","description":"OverdueLater, OverdueSoon, Overdue, or CompletedInTime"}}}},"TaskSource":{"type":"object","description":"Task source information","properties":{"SourceName":{"type":"string","description":"Agent, Workflow, Maestro, CaseManagement, or Default"},"SourceId":{"type":"string"},"JobId":{"type":"string"}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="error6" name="Error" type="jsonSchema" elementId="Activity_hOUdUf"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="farmerName3" name="farmerName" type="string" elementId="Activity_hOUdUf" />
        <uipath:inputOutput id="grantName" name="grantName" type="string" elementId="Activity_hOUdUf" />
        <uipath:inputOutput id="agentAction" name="agentAction" type="string" elementId="Activity_hOUdUf" />
        <uipath:inputOutput id="currentStatus" name="currentStatus" type="string" elementId="Activity_hOUdUf" />
        <uipath:inputOutput id="submissionPackage" name="submissionPackage" type="jsonSchema" elementId="Activity_hOUdUf"><![CDATA[{"type":"object","description":"Present only when agentAction is 'prepare-submission-package'. Contains everything the farmer needs to submit the application correctly.","properties":{"readinessAssessment":{"type":"string","enum":["Ready to Submit","Almost Ready — Minor Issues","Not Ready — Critical Items Missing"],"description":"Overall readiness verdict based on documents checklist and missing items."},"coverLetter":{"type":"string","description":"Complete formal cover letter addressed to the granting organization. Includes applicant details, project title, amount requested, brief project summary, list of enclosed documents, and a professional sign-off."},"documentsChecklistVerified":{"type":"array","items":{"type":"object","properties":{"document":{"type":"string"},"status":{"type":"string","enum":["Ready","Missing","Needs Update"]},"note":{"type":"string"}}},"description":"Status check of every document in the submission package."},"submissionGuide":{"type":"string","description":"Step-by-step plain-language guide (5 to 8 steps) on exactly how to submit this application specific to the submission method chosen."},"criticalWarnings":{"type":"array","items":{"type":"string"},"description":"Critical issues that must be resolved before submission. Empty array if none."},"submissionTips":{"type":"array","items":{"type":"string"},"description":"Practical tips for a successful submission (e.g., 'Make 3 copies of all documents', 'Arrive at the office before 10am')."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="confirmationPackage" name="confirmationPackage" type="jsonSchema" elementId="Activity_hOUdUf"><![CDATA[{"type":"object","description":"Present only when agentAction is 'generate-confirmation'. Contains all confirmation messages for the farmer after successful submission.","properties":{"congratulatoryMessage":{"type":"string","description":"Warm encouraging message to the farmer confirming successful submission. Mentions the grant name, submission date, reference number if available, and next steps."},"smsMessage":{"type":"string","description":"Short SMS-ready confirmation message (max 160 characters) the farmer can receive on their phone."},"whatsappMessage":{"type":"string","description":"Friendly WhatsApp-style confirmation message (150 to 250 words) with appropriate emojis. Confirms submission, lists key details, and tells the farmer what to expect next."},"submissionSummaryCard":{"type":"object","properties":{"farmerName":{"type":"string"},"grantName":{"type":"string"},"projectTitle":{"type":"string"},"amountRequested":{"type":"string"},"submissionDate":{"type":"string"},"referenceNumber":{"type":"string"},"expectedResponseTime":{"type":"string"},"nextStep":{"type":"string"}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="reminderSchedule" name="reminderSchedule" type="jsonSchema" elementId="Activity_hOUdUf"><![CDATA[{"type":"object","description":"Present only when agentAction is 'set-reminders'. Contains a full timeline of reminders from pre-submission through to expected decision.","properties":{"totalReminders":{"type":"integer"},"reminders":{"type":"array","items":{"type":"object","properties":{"reminderNumber":{"type":"integer"},"triggerEvent":{"type":"string","description":"What triggers this reminder (e.g., '7 days before deadline', '2 weeks after submission')."},"suggestedDate":{"type":"string","description":"Suggested calendar date (YYYY-MM-DD) or relative description."},"channel":{"type":"string","enum":["SMS","WhatsApp","Email","Phone Call","In-Person Visit"]},"smsText":{"type":"string","description":"Short SMS reminder (max 160 characters)."},"fullMessage":{"type":"string","description":"Full reminder message (100 to 200 words) with context, action required, and encouragement."},"actionRequired":{"type":"string","description":"What the farmer must do in response to this reminder."}}}},"calendarSummary":{"type":"string","description":"Plain-language overview of the full reminder timeline describing all key dates and milestones."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="trackingAndFollowUp" name="trackingAndFollowUp" type="jsonSchema" elementId="Activity_hOUdUf"><![CDATA[{"type":"object","description":"Present only when agentAction is 'track-and-follow-up'. Contains status assessment and ready-to-send follow-up communications.","properties":{"statusAssessment":{"type":"string","description":"Assessment of where the application stands, how long it has been in current status, whether the timeline is normal, and what the farmer should expect next."},"urgencyLevel":{"type":"string","enum":["Routine","Follow-Up Due","Action Required","Urgent"]},"followUpEmailDraft":{"type":"string","description":"Complete professional follow-up email draft addressed to the granting organization. Mentions reference number, project title, submission date, and politely inquires about status."},"followUpWhatsappMessage":{"type":"string","description":"Shorter polite follow-up message in WhatsApp format (80 to 120 words). Friendly but professional."},"phoneScriptForFollowUp":{"type":"string","description":"Word-for-word phone script the farmer can use when calling the grant office. Includes greeting, self-introduction, reference number, what to say, questions to ask, and how to close."},"nextActions":{"type":"array","items":{"type":"object","properties":{"action":{"type":"string"},"timeline":{"type":"string"},"channel":{"type":"string"}}},"description":"Ordered list of 3 to 5 concrete next actions for the farmer."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="additionalInfoResponse" name="additionalInfoResponse" type="jsonSchema" elementId="Activity_hOUdUf"><![CDATA[{"type":"object","description":"Present only when agentAction is 'handle-additional-info-request'. Helps farmer respond to a request for more documents or information.","properties":{"acknowledgementLetter":{"type":"string","description":"Formal letter acknowledging the grantor request, confirming the farmer will provide the items, and committing to a response timeline."},"itemsToProvide":{"type":"array","items":{"type":"object","properties":{"item":{"type":"string"},"howToObtain":{"type":"string","description":"Practical guidance on where and how the farmer can obtain this item in Nigeria."},"estimatedTimeToObtain":{"type":"string"}}}},"farmerInstructions":{"type":"string","description":"Friendly plain-language instructions for the farmer explaining what was requested and exactly what they need to do step by step."},"responseDeadlineSuggestion":{"type":"string","description":"Suggested timeframe for responding to the grantor (e.g., 'Aim to respond within 5 to 7 business days')."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="rejectionResponse" name="rejectionResponse" type="jsonSchema" elementId="Activity_hOUdUf"><![CDATA[{"type":"object","description":"Present only when agentAction is 'generate-rejection-response'. Helps the farmer process a rejection and plan next steps.","properties":{"farmerSupportMessage":{"type":"string","description":"Empathetic encouraging message acknowledging the disappointment, normalizing rejection in the grant process, and motivating the farmer to move forward."},"rejectionAnalysis":{"type":"string","description":"Professional analysis of the likely reasons for rejection and what it means practically for the farmer's next steps."},"appealLetter":{"type":"string","description":"Formal appeal letter professionally challenging the rejection reason, providing additional context, and requesting reconsideration or feedback."},"improvementPlan":{"type":"array","items":{"type":"string"},"description":"Concrete actions the farmer can take to strengthen their application for the next cycle."},"alternativeOptions":{"type":"array","items":{"type":"string"},"description":"Specific alternative grant programs or funding sources the farmer can pivot to."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="farmerFacingMessagePrimary" name="farmerFacingMessagePrimary" type="string" elementId="Activity_hOUdUf" />
        <uipath:inputOutput id="agentSummary" name="agentSummary" type="string" elementId="Activity_hOUdUf" />
        <uipath:inputOutput id="error4" name="Error" type="jsonSchema" elementId="Activity_4HvjEH"><![CDATA[{"type":"object","properties":{"code":{"type":"string"},"message":{"type":"string"},"detail":{"type":"string"},"category":{"type":"string"},"status":{"type":"number"},"element":{"type":"string"}}}]]></uipath:inputOutput>
        <uipath:inputOutput id="proposalTitle" name="proposalTitle" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="applicantName2" name="applicantName" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="organizationName" name="organizationName" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="targetGrant2" name="targetGrant" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="grantingOrganization" name="grantingOrganization" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="requestedAmountNgn" name="requestedAmountNGN" type="number" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="projectDurationMonths" name="projectDurationMonths" type="integer" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="coverPage" name="coverPage" type="jsonSchema" elementId="Activity_4HvjEH"><![CDATA[{"type":"object","description":"Structured cover page metadata. Populated when documentType is 'full_proposal' or 'both'. Null object when documentType is 'application_letter'.","properties":{"projectTitle":{"type":"string","description":"Full project title as it appears on the cover page."},"submittedBy":{"type":"string","description":"Applicant or organization name."},"submittedTo":{"type":"string","description":"Granting organization name and department."},"projectLocation":{"type":"string","description":"State and LGA of the project."},"projectDuration":{"type":"string","description":"Project duration in readable format (e.g., '18 months: January 2026 – June 2027')."},"totalFundingRequested":{"type":"string","description":"Amount in NGN formatted with commas (e.g., 'NGN 5,000,000')."},"submissionDate":{"type":"string","description":"Submission date in format 'Month YYYY'."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="executiveSummary" name="executiveSummary" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="problemStatement" name="problemStatement" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="projectDescription" name="projectDescription" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="projectObjectives" name="projectObjectives" type="jsonSchema" subType="string" elementId="Activity_4HvjEH"><![CDATA[{"type":"array","description":"3–5 SMART objectives (Specific, Measurable, Achievable, Relevant, Time-bound). Each written as a complete action statement. Empty array when documentType is 'application_letter'.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="methodology" name="methodology" type="jsonSchema" elementId="Activity_4HvjEH"><![CDATA[{"type":"object","description":"Structured methodology with phased activities. Populated when documentType is 'full_proposal' or 'both'.","properties":{"overview":{"type":"string","description":"100–150 word overview of the overall approach."},"activities":{"type":"array","description":"Phased activity plan covering the full project duration.","items":{"type":"object","properties":{"phase":{"type":"string","description":"Phase name (e.g., 'Phase 1: Mobilization and Procurement')."},"timeline":{"type":"string","description":"Time period for this phase (e.g., 'Month 1–3')."},"activities":{"type":"array","description":"List of specific activities in this phase.","items":{"type":"string"}}}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="budgetBreakdown" name="budgetBreakdown" type="jsonSchema" subType="object" elementId="Activity_4HvjEH"><![CDATA[{"type":"array","description":"Itemized budget summing to requestedAmountNGN. Empty array when documentType is 'application_letter'.","items":{"type":"object","properties":{"lineItem":{"type":"string","description":"Budget item name (e.g., 'Irrigation Equipment', 'Labour Costs')."},"description":{"type":"string","description":"Brief description of what this covers."},"amountNGN":{"type":"number","description":"Amount in NGN for this line item."},"percentageOfTotal":{"type":"string","description":"Percentage of total budget (e.g., '25%')."},"justification":{"type":"string","description":"1–2 sentence justification for this expenditure."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="budgetNarrative" name="budgetNarrative" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="expectedOutcomes" name="expectedOutcomes" type="jsonSchema" elementId="Activity_4HvjEH"><![CDATA[{"type":"object","description":"Structured outcomes covering direct outputs, impact, and beneficiary breakdown. Populated when full proposal is generated.","properties":{"directOutputs":{"type":"array","description":"Concrete measurable deliverables.","items":{"type":"string"}},"impactStatements":{"type":"array","description":"Broader impact statements.","items":{"type":"string"}},"beneficiaries":{"type":"object","properties":{"directBeneficiaries":{"type":"integer","description":"Number of people directly benefiting."},"indirectBeneficiaries":{"type":"integer","description":"Number of people indirectly benefiting."},"womenBeneficiaries":{"type":"string","description":"Proportion or number of women beneficiaries (e.g., '60% women', '120 women farmers')."},"youthBeneficiaries":{"type":"string","description":"Proportion or number of youth beneficiaries (e.g., '35% youth aged 18–35')."}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="sustainabilityPlan" name="sustainabilityPlan" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="organizationalCapacity" name="organizationalCapacity" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="monitoringAndEvaluation" name="monitoringAndEvaluation" type="jsonSchema" elementId="Activity_4HvjEH"><![CDATA[{"type":"object","description":"M&E framework for tracking project progress. Populated when full proposal is generated.","properties":{"approach":{"type":"string","description":"100–150 word description of the overall M&E approach."},"keyIndicators":{"type":"array","description":"3–5 KPIs with baselines, targets, and measurement methods.","items":{"type":"object","properties":{"indicator":{"type":"string","description":"Name of the performance indicator."},"baseline":{"type":"string","description":"Starting value before the project."},"target":{"type":"string","description":"Expected value by project end."},"measurementMethod":{"type":"string","description":"How this will be measured."}}}},"reportingSchedule":{"type":"string","description":"Reporting frequency and format (e.g., 'Monthly activity reports, quarterly financial reports, final impact report at project close')."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="conclusion" name="conclusion" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="fullProposalText" name="fullProposalText" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="proposalQualityScore" name="proposalQualityScore" type="integer" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="writingNotes" name="writingNotes" type="jsonSchema" subType="string" elementId="Activity_4HvjEH"><![CDATA[{"type":"array","description":"1–3 specific improvement notes identifying what additional farmer information would strengthen the documents (e.g., 'Adding a letter of support from the cooperative chairman would significantly increase credibility', 'Including local post-harvest loss statistics for Kano State would strengthen the problem statement'). Empty array if all documents are strong as-is.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="documentType" name="documentType" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="applicationLetters" name="applicationLetters" type="jsonSchema" subType="object" elementId="Activity_4HvjEH"><![CDATA[{"type":"array","description":"Array of ready-to-submit formal application letters. Populated when documentType is 'application_letter' or 'both'. Empty array [] when documentType is 'full_proposal'.","items":{"type":"object","properties":{"grantName":{"type":"string","description":"Name of the grant this letter is for."},"letterType":{"type":"string","description":"Format of the letter based on grantCategory: 'formal_government' for CBN/BOA/FMARD, 'state_ministry' for state programs, 'microfinance' for NIRSAL/MFB programs, 'ngo_eoi' for NGO expression of interest, 'development_bank' for World Bank/IFAD/AfDB.","enum":["formal_government","state_ministry","microfinance","ngo_eoi","development_bank"]},"recipientAddress":{"type":"string","description":"Full recipient address block for the letter header (e.g., 'The Director, Development Finance Department, Central Bank of Nigeria, CBN Headquarters, Abuja')."},"subject":{"type":"string","description":"Subject line of the letter in uppercase (e.g., 'RE: APPLICATION FOR THE CBN ANCHOR BORROWERS PROGRAMME — RICE AND MAIZE PRODUCTION, KANO STATE')."},"letterBody":{"type":"string","description":"Complete formatted application letter body, ready to print and sign. Includes: farmer address header, date (June 2026), recipient address, subject line, salutation, 4–5 body paragraphs (introduction, farm profile, funding need, grant alignment, closing), complimentary close, and signature block. 400–600 words. Must be complete — not a template, not a draft."},"enclosureList":{"type":"array","description":"List of all supporting documents to attach with the letter (e.g., 'Certified copy of NIN slip', 'CAC Certificate', 'Land document or C of O', 'Recent passport photograph', 'Bank statement (last 6 months)').","items":{"type":"string"}},"recommendedSubmissionMethod":{"type":"string","description":"Step-by-step instructions on how to physically or digitally submit this specific letter (e.g., 'Print 3 copies. Hand-deliver to the nearest CBN branch or participating microfinance bank. Request an acknowledgement receipt at submission.')."},"wordCount":{"type":"integer","description":"Approximate word count of the letterBody."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="preparationChecklist" name="preparationChecklist" type="jsonSchema" subType="string" elementId="Activity_4HvjEH"><![CDATA[{"type":"array","description":"Always populated. Step-by-step checklist of everything the farmer must do and gather before submitting (e.g., 'Print 3 copies of the application letter on A4 paper', 'Obtain certified copy of CAC certificate from a notary public', 'Ensure BVN is linked to an active bank account', 'Attach one recent passport photograph per copy'). Minimum 6 items.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="submissionInstructions" name="submissionInstructions" type="string" elementId="Activity_4HvjEH" />
        <uipath:inputOutput id="disclaimer2" name="disclaimer" type="string" elementId="Activity_4HvjEH" />
      </uipath:variables>
      <uipath:bindings version="v1">
        <uipath:binding id="biDfveeQk" name="folderPath" type="string" resource="process" resourceKey="Grant Discovery &#38; Matching Agent" propertyAttribute="folderPath" />
        <uipath:binding id="bQDCOPWuv" name="name" type="string" default="Grant Discovery &#38; Matching Agent" resource="process" resourceKey="Grant Discovery &#38; Matching Agent" propertyAttribute="name" />
        <uipath:binding id="bXI5fqkjq" name="folderPath" type="string" resource="process" resourceKey="Eligibility &#38; Risk Assessment Agent" propertyAttribute="folderPath" />
        <uipath:binding id="buNQxReGw" name="name" type="string" default="Eligibility &#38; Risk Assessment Agent" resource="process" resourceKey="Eligibility &#38; Risk Assessment Agent" propertyAttribute="name" />
        <uipath:binding id="bfB4Hbmbk" name="folderPath" type="string" resource="process" resourceKey="Document Understanding Agent" propertyAttribute="folderPath" />
        <uipath:binding id="bMfbAXUEm" name="name" type="string" default="Document Understanding Agent" resource="process" resourceKey="Document Understanding Agent" propertyAttribute="name" />
        <uipath:binding id="bCGv8jdRt" name="folderPath" type="string" resource="process" resourceKey="Proposal Generation Agent" propertyAttribute="folderPath" />
        <uipath:binding id="buHr8Sc3d" name="name" type="string" default="Proposal Generation Agent" resource="process" resourceKey="Proposal Generation Agent" propertyAttribute="name" />
        <uipath:binding id="bAyUdePPd" name="folderPath" type="string" default=".entities" resource="app" resourceKey=".entities.SimpleApprovalApp" propertyAttribute="folderPath" />
        <uipath:binding id="beHIGNbTt" name="name" type="string" default="SimpleApprovalApp" resource="app" resourceKey=".entities.SimpleApprovalApp" propertyAttribute="name" />
        <uipath:binding id="bMzdgQhlc" name="folderPath" type="string" resource="process" resourceKey="Submission &#38; Follow-up Agent" propertyAttribute="folderPath" />
        <uipath:binding id="bqLifERAW" name="name" type="string" default="Submission &#38; Follow-up Agent" resource="process" resourceKey="Submission &#38; Follow-up Agent" propertyAttribute="name" />
        <uipath:binding id="bBv6v8bJn" name="folderPath" type="string" resource="process" resourceKey="SimpleApprovalApp" propertyAttribute="folderPath" />
        <uipath:binding id="bfstSTSqf" name="name" type="string" default="SimpleApprovalApp" resource="process" resourceKey="SimpleApprovalApp" propertyAttribute="name" />
        <uipath:binding id="bocnJHoET" name="folderPath" type="string" resource="app" resourceKey="SimpleApprovalApp" propertyAttribute="folderPath" />
        <uipath:binding id="bw2oL4iG8" name="name" type="string" default="SimpleApprovalApp" resource="app" resourceKey="SimpleApprovalApp" propertyAttribute="name" />
        <uipath:binding id="bC2vIlmas" name="folderPath" type="string" default="nwajariemmanuel355@gmail.com&#39;s workspace/Debug_Solution 1" resource="process" resourceKey="nwajariemmanuel355@gmail.com&#39;s workspace/Debug_Solution 1.Submission &#38; Follow-up Agent" propertyAttribute="folderPath" />
        <uipath:binding id="b1M3Snecl" name="name" type="string" default="Submission &#38; Follow-up Agent" resource="process" resourceKey="nwajariemmanuel355@gmail.com&#39;s workspace/Debug_Solution 1.Submission &#38; Follow-up Agent" propertyAttribute="name" />
      </uipath:bindings>
      <uipath:migrationVersion version="15" />
      <uipath:intsvcActivityConfig version="v2" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="start_event" name="Farmer Submits Grant Application">
      <bpmn:extensionElements>
        <uipath:entryPointId value="9014356b-5c01-4d6c-834e-f7a3afa06aaf" />
      </bpmn:extensionElements>
      <bpmn:outgoing>flow_start_to_validate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_receive_validate" name="API: Receive &#38; Validate Farm Application Data">
      <bpmn:incoming>flow_start_to_validate</bpmn:incoming>
      <bpmn:incoming>flow_timer_to_validate</bpmn:incoming>
      <bpmn:outgoing>flow_validate_to_gw_complete</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_data_complete" name="Is Application Data Complete?" default="flow_data_complete_yes">
      <bpmn:incoming>flow_validate_to_gw_complete</bpmn:incoming>
      <bpmn:outgoing>flow_data_complete_no</bpmn:outgoing>
      <bpmn:outgoing>flow_data_complete_yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_request_missing_info" name="Request Missing Information from Farmer">
      <bpmn:incoming>flow_data_complete_no</bpmn:incoming>
      <bpmn:outgoing>flow_request_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="timer_await_farmer" name="Await Farmer Response (48hrs)">
      <bpmn:incoming>flow_request_to_timer</bpmn:incoming>
      <bpmn:outgoing>flow_timer_to_validate</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT48H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="task_grant_discovery" name="Grant Discovery Agent: Search &#38; Match Eligible Grants">
      <bpmn:incoming>flow_data_complete_yes</bpmn:incoming>
      <bpmn:outgoing>flow_discovery_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_grants_found" name="Were Matching Grants Found?">
      <bpmn:incoming>flow_discovery_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_grants_found_no</bpmn:outgoing>
      <bpmn:outgoing>flow_grants_found_to_present</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_notify_no_grants" name="Submission &#38; Follow-up Agent: Notify Farmer - No Grants Available">
      <bpmn:incoming>flow_grants_found_no</bpmn:incoming>
      <bpmn:outgoing>flow_notify_no_grants_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_no_grants" name="No Matching Grants Found">
      <bpmn:incoming>flow_notify_no_grants_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_eligibility_assessment" name="Eligibility &#38; Assessment Agent: Analyze Grant Requirements vs Farmer Profile">
      <bpmn:incoming>flow_other_grants_yes</bpmn:incoming>
      <bpmn:outgoing>flow_assessment_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_requirements_met" name="Does Farmer Meet All Grant Requirements?" default="flow_reqs_met_yes">
      <bpmn:incoming>flow_assessment_to_gw</bpmn:incoming>
      <bpmn:incoming>flow_deep_dive_to_gw_reqs_met</bpmn:incoming>
      <bpmn:outgoing>flow_reqs_met_no</bpmn:outgoing>
      <bpmn:outgoing>flow_reqs_met_yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gw_other_grants_to_check" name="Are There Other Grants to Check?" default="flow_other_grants_yes">
      <bpmn:incoming>flow_reqs_met_no</bpmn:incoming>
      <bpmn:outgoing>flow_other_grants_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_other_grants_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_notify_reqs_not_met" name="Submission &#38; Follow-up Agent: Notify Farmer - Requirements Not Met">
      <bpmn:incoming>flow_other_grants_no</bpmn:incoming>
      <bpmn:outgoing>flow_notify_reqs_not_met_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_reqs_not_met" name="Process Ended - Requirements Not Met">
      <bpmn:incoming>flow_notify_reqs_not_met_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_check_docs_required" name="Document &#38; Understanding Agent: Check Required Documents for Grant">
      <bpmn:incoming>flow_reqs_met_yes</bpmn:incoming>
      <bpmn:outgoing>flow_check_docs_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_docs_required" name="Are Documents Required for This Grant?" default="flow_docs_required_yes">
      <bpmn:incoming>flow_check_docs_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_docs_required_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_docs_required_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_identify_doc_types" name="Document &#38; Understanding Agent: Identify Required Document Types (PDF, Excel, etc.)">
      <bpmn:incoming>flow_docs_required_yes</bpmn:incoming>
      <bpmn:outgoing>flow_identify_to_upload</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="task_farmer_uploads_docs" name="Farmer Uploads Required Documents via Web App">
      <bpmn:incoming>flow_identify_to_upload</bpmn:incoming>
      <bpmn:outgoing>flow_upload_to_analyze</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="task_analyze_docs" name="Document &#38; Understanding Agent: Analyze Documents &#38; Extract Key Details">
      <bpmn:incoming>flow_upload_to_analyze</bpmn:incoming>
      <bpmn:incoming>flow_query_doc_to_analyze</bpmn:incoming>
      <bpmn:outgoing>flow_analyze_to_prepare_instructions</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="boundary_doc_analysis_failed" name="Document Analysis Failed" cancelActivity="false" attachedToRef="task_analyze_docs">
      <bpmn:outgoing>flow_boundary_doc_to_query</bpmn:outgoing>
      <bpmn:errorEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="task_query_for_clarification_doc" name="Document &#38; Understanding Agent Queries Eligibility &#38; Assessment Agent for Clarification">
      <bpmn:incoming>flow_boundary_doc_to_query</bpmn:incoming>
      <bpmn:outgoing>flow_query_doc_to_analyze</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_prepare_doc_instructions" name="Document &#38; Understanding Agent: Prepare Document Attachment Instructions for RPA">
      <bpmn:incoming>flow_analyze_to_prepare_instructions</bpmn:incoming>
      <bpmn:outgoing>flow_prepare_instructions_to_collect</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_collect_grant_details" name="Proposal Agent: Collect Grant Details from Eligibility &#38; Assessment Agent">
      <bpmn:incoming>flow_docs_required_no</bpmn:incoming>
      <bpmn:incoming>flow_prepare_instructions_to_collect</bpmn:incoming>
      <bpmn:outgoing>flow_collect_to_compose</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_compose_proposal" name="Proposal Agent: Compose Tailored Grant Proposal">
      <bpmn:incoming>flow_collect_to_compose</bpmn:incoming>
      <bpmn:incoming>flow_query_proposal_to_compose</bpmn:incoming>
      <bpmn:outgoing>flow_compose_to_review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="boundary_proposal_error" name="Unclear Grant Requirements" cancelActivity="false" attachedToRef="task_compose_proposal">
      <bpmn:outgoing>flow_boundary_proposal_to_query</bpmn:outgoing>
      <bpmn:errorEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="task_query_for_clarification_proposal" name="Proposal Agent Queries Eligibility &#38; Assessment Agent for Clarification">
      <bpmn:incoming>flow_boundary_proposal_to_query</bpmn:incoming>
      <bpmn:outgoing>flow_query_proposal_to_compose</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="task_farmer_reviews_proposal" name="Farmer Reviews Grant Proposal in Web App">
      <bpmn:incoming>flow_compose_to_review</bpmn:incoming>
      <bpmn:incoming>flow_regenerate_to_review</bpmn:incoming>
      <bpmn:outgoing>flow_review_to_gw_approve</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_farmer_approved_proposal" name="Did Farmer Approve the Proposal?" default="flow_farmer_approved_yes">
      <bpmn:incoming>flow_review_to_gw_approve</bpmn:incoming>
      <bpmn:outgoing>flow_farmer_approved_no</bpmn:outgoing>
      <bpmn:outgoing>flow_farmer_approved_yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_regenerate_proposal" name="Proposal Agent: Regenerate Proposal Based on Farmer Feedback">
      <bpmn:incoming>flow_farmer_approved_no</bpmn:incoming>
      <bpmn:outgoing>flow_regenerate_to_review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_package_for_rpa" name="Proposal Agent: Package All Data &#38; Send to RPA Submission Robot">
      <bpmn:incoming>flow_farmer_approved_yes</bpmn:incoming>
      <bpmn:outgoing>flow_package_to_query_fields</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_rpa_query_fields" name="RPA Portal Submission Robot: Query Required Form Fields on Grant Portal">
      <bpmn:incoming>flow_package_to_query_fields</bpmn:incoming>
      <bpmn:outgoing>flow_query_fields_to_submit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_rpa_submit" name="RPA Portal Submission Robot: Fill &#38; Submit Application Form">
      <bpmn:incoming>flow_query_fields_to_submit</bpmn:incoming>
      <bpmn:incoming>flow_retry_yes</bpmn:incoming>
      <bpmn:outgoing>flow_submit_to_notify_success</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="boundary_submission_failed" name="Portal Unavailable / Submission Failed" cancelActivity="false" attachedToRef="task_rpa_submit">
      <bpmn:outgoing>flow_boundary_submit_to_notify</bpmn:outgoing>
      <bpmn:errorEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="task_notify_portal_issue" name="Submission &#38; Follow-up Agent: Notify Admin &#38; Farmer of Portal Issue">
      <bpmn:incoming>flow_boundary_submit_to_notify</bpmn:incoming>
      <bpmn:outgoing>flow_notify_issue_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="timer_retry_submit" name="Retry After 1 Hour">
      <bpmn:incoming>flow_notify_issue_to_timer</bpmn:incoming>
      <bpmn:outgoing>flow_timer_to_retry_gw</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="gw_retry_limit" name="Retry &#60; 3?" default="flow_retry_yes">
      <bpmn:incoming>flow_timer_to_retry_gw</bpmn:incoming>
      <bpmn:outgoing>flow_retry_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_retry_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="end_submission_failed" name="Submission Failed - Manual Intervention Required">
      <bpmn:incoming>flow_retry_no</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_notify_successful_submission" name="Submission &#38; Follow-up Agent: Notify Farmer of Successful Submission">
      <bpmn:incoming>flow_submit_to_notify_success</bpmn:incoming>
      <bpmn:outgoing>flow_notify_success_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="timer_monitor_status" name="Monitor Application Status (Every 24hrs)">
      <bpmn:incoming>flow_notify_success_to_timer</bpmn:incoming>
      <bpmn:incoming>flow_update_pending_to_timer</bpmn:incoming>
      <bpmn:outgoing>flow_timer_monitor_to_check</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="task_rpa_check_status" name="RPA Portal Submission Robot: Check Application Status on Portal">
      <bpmn:incoming>flow_timer_monitor_to_check</bpmn:incoming>
      <bpmn:outgoing>flow_check_status_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_app_status" name="What is the Current Application Status?" default="flow_status_pending">
      <bpmn:incoming>flow_check_status_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_status_pending</bpmn:outgoing>
      <bpmn:outgoing>flow_status_approved</bpmn:outgoing>
      <bpmn:outgoing>flow_status_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_update_farmer_pending" name="Submission &#38; Follow-up Agent: Update Farmer on Current Stage via Web App">
      <bpmn:incoming>flow_status_pending</bpmn:incoming>
      <bpmn:outgoing>flow_update_pending_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_send_congrats" name="Submission &#38; Follow-up Agent: Send Congratulations &#38; Grant Acceptance Details to Farmer">
      <bpmn:incoming>flow_status_approved</bpmn:incoming>
      <bpmn:outgoing>flow_congrats_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_approved" name="Grant Application APPROVED - SUCCESS ✓">
      <bpmn:incoming>flow_congrats_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_rpa_get_rejection_reason" name="RPA Portal Submission Robot: Retrieve Rejection Reason from Portal">
      <bpmn:incoming>flow_status_rejected</bpmn:incoming>
      <bpmn:outgoing>flow_get_reason_to_review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="task_specialist_reviews_rejection" name="Grant Specialist Reviews Rejection &#38; Decides on Appeal">
      <bpmn:incoming>flow_get_reason_to_review</bpmn:incoming>
      <bpmn:outgoing>flow_review_rejection_to_gw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_appeal_worthy" name="Is an Appeal Worth Filing?" default="flow_appeal_no">
      <bpmn:incoming>flow_review_rejection_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_appeal_no</bpmn:outgoing>
      <bpmn:outgoing>flow_appeal_yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_send_rejection_analysis" name="Submission &#38; Follow-up Agent: Send Rejection Analysis &#38; Improvement Recommendations">
      <bpmn:incoming>flow_appeal_no</bpmn:incoming>
      <bpmn:outgoing>flow_rejection_analysis_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_rejected_recommendations" name="Application Rejected - Recommendations Sent">
      <bpmn:incoming>flow_rejection_analysis_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_prepare_appeal" name="Proposal Agent: Prepare Appeal Documentation">
      <bpmn:incoming>flow_appeal_yes</bpmn:incoming>
      <bpmn:outgoing>flow_prepare_appeal_to_file</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_rpa_file_appeal" name="RPA Portal Submission Robot: File Appeal on Portal">
      <bpmn:incoming>flow_prepare_appeal_to_file</bpmn:incoming>
      <bpmn:outgoing>flow_file_appeal_to_notify</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_notify_appeal_filed" name="Submission &#38; Follow-up Agent: Notify Farmer - Appeal Filed">
      <bpmn:incoming>flow_file_appeal_to_notify</bpmn:incoming>
      <bpmn:outgoing>flow_notify_appeal_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="timer_await_appeal" name="Await Appeal Decision">
      <bpmn:incoming>flow_notify_appeal_to_timer</bpmn:incoming>
      <bpmn:outgoing>flow_timer_appeal_to_check</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P14D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="task_rpa_check_appeal_status" name="RPA Robot: Check Appeal Status">
      <bpmn:incoming>flow_timer_appeal_to_check</bpmn:incoming>
      <bpmn:outgoing>flow_check_appeal_to_gw</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_appeal_decision" name="Appeal Decision?" default="flow_appeal_approved">
      <bpmn:incoming>flow_check_appeal_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_appeal_approved</bpmn:outgoing>
      <bpmn:outgoing>flow_appeal_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_notify_appeal_won" name="Submission &#38; Follow-up Agent: Notify Farmer - Appeal Won!">
      <bpmn:incoming>flow_appeal_approved</bpmn:incoming>
      <bpmn:outgoing>flow_appeal_won_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_appeal_approved" name="Appeal APPROVED - Grant Secured ✓">
      <bpmn:incoming>flow_appeal_won_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_send_final_report" name="Submission &#38; Follow-up Agent: Send Final Report &#38; Future Recommendations to Farmer">
      <bpmn:incoming>flow_appeal_rejected</bpmn:incoming>
      <bpmn:outgoing>flow_final_report_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_final_rejection" name="Final Rejection - Case Closed">
      <bpmn:incoming>flow_final_report_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_present_options" name="Submission &#38; Follow-up Agent: Present Grant Options to Farmer">
      <bpmn:incoming>flow_grants_found_to_present</bpmn:incoming>
      <bpmn:outgoing>flow_present_to_select</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="task_farmer_selects_grant" name="Farmer Selects Which Grant to Apply For">
      <bpmn:incoming>flow_present_to_select</bpmn:incoming>
      <bpmn:outgoing>flow_select_to_deep_dive</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="task_deep_dive_assessment" name="Eligibility &#38; Risk Assessment Agent: Deep-Dive Assessment of Selected Grant">
      <bpmn:incoming>flow_select_to_deep_dive</bpmn:incoming>
      <bpmn:outgoing>flow_deep_dive_to_gw_reqs_met</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="flow_start_to_validate" sourceRef="start_event" targetRef="task_receive_validate" />
    <bpmn:sequenceFlow id="flow_validate_to_gw_complete" sourceRef="task_receive_validate" targetRef="gw_data_complete" />
    <bpmn:sequenceFlow id="flow_data_complete_no" name="No" sourceRef="gw_data_complete" targetRef="task_request_missing_info">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${!isComplete}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_request_to_timer" sourceRef="task_request_missing_info" targetRef="timer_await_farmer" />
    <bpmn:sequenceFlow id="flow_timer_to_validate" sourceRef="timer_await_farmer" targetRef="task_receive_validate" />
    <bpmn:sequenceFlow id="flow_data_complete_yes" name="Yes" sourceRef="gw_data_complete" targetRef="task_grant_discovery">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${isComplete}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_discovery_to_gw" sourceRef="task_grant_discovery" targetRef="gw_grants_found" />
    <bpmn:sequenceFlow id="flow_grants_found_no" name="No" sourceRef="gw_grants_found" targetRef="task_notify_no_grants">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${!grantsFound}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_notify_no_grants_to_end" sourceRef="task_notify_no_grants" targetRef="end_no_grants" />
    <bpmn:sequenceFlow id="flow_assessment_to_gw" sourceRef="task_eligibility_assessment" targetRef="gw_requirements_met" />
    <bpmn:sequenceFlow id="flow_reqs_met_no" name="No" sourceRef="gw_requirements_met" targetRef="gw_other_grants_to_check">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${!requirementsMet}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_other_grants_yes" name="Yes" sourceRef="gw_other_grants_to_check" targetRef="task_eligibility_assessment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${otherGrantsExist}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_other_grants_no" name="No" sourceRef="gw_other_grants_to_check" targetRef="task_notify_reqs_not_met">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${!otherGrantsExist}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_notify_reqs_not_met_to_end" sourceRef="task_notify_reqs_not_met" targetRef="end_reqs_not_met" />
    <bpmn:sequenceFlow id="flow_reqs_met_yes" name="Yes" sourceRef="gw_requirements_met" targetRef="task_check_docs_required">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${requirementsMet}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_check_docs_to_gw" sourceRef="task_check_docs_required" targetRef="gw_docs_required" />
    <bpmn:sequenceFlow id="flow_docs_required_yes" name="Yes" sourceRef="gw_docs_required" targetRef="task_identify_doc_types">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${documentsRequired}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_identify_to_upload" sourceRef="task_identify_doc_types" targetRef="task_farmer_uploads_docs" />
    <bpmn:sequenceFlow id="flow_upload_to_analyze" sourceRef="task_farmer_uploads_docs" targetRef="task_analyze_docs" />
    <bpmn:sequenceFlow id="flow_boundary_doc_to_query" sourceRef="boundary_doc_analysis_failed" targetRef="task_query_for_clarification_doc" />
    <bpmn:sequenceFlow id="flow_query_doc_to_analyze" sourceRef="task_query_for_clarification_doc" targetRef="task_analyze_docs" />
    <bpmn:sequenceFlow id="flow_analyze_to_prepare_instructions" sourceRef="task_analyze_docs" targetRef="task_prepare_doc_instructions" />
    <bpmn:sequenceFlow id="flow_docs_required_no" name="No" sourceRef="gw_docs_required" targetRef="task_collect_grant_details">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${!documentsRequired}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_prepare_instructions_to_collect" sourceRef="task_prepare_doc_instructions" targetRef="task_collect_grant_details" />
    <bpmn:sequenceFlow id="flow_collect_to_compose" sourceRef="task_collect_grant_details" targetRef="task_compose_proposal" />
    <bpmn:sequenceFlow id="flow_boundary_proposal_to_query" sourceRef="boundary_proposal_error" targetRef="task_query_for_clarification_proposal" />
    <bpmn:sequenceFlow id="flow_query_proposal_to_compose" sourceRef="task_query_for_clarification_proposal" targetRef="task_compose_proposal" />
    <bpmn:sequenceFlow id="flow_compose_to_review" sourceRef="task_compose_proposal" targetRef="task_farmer_reviews_proposal" />
    <bpmn:sequenceFlow id="flow_review_to_gw_approve" sourceRef="task_farmer_reviews_proposal" targetRef="gw_farmer_approved_proposal" />
    <bpmn:sequenceFlow id="flow_farmer_approved_no" name="No" sourceRef="gw_farmer_approved_proposal" targetRef="task_regenerate_proposal">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${!proposalApproved}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_regenerate_to_review" sourceRef="task_regenerate_proposal" targetRef="task_farmer_reviews_proposal" />
    <bpmn:sequenceFlow id="flow_farmer_approved_yes" name="Yes" sourceRef="gw_farmer_approved_proposal" targetRef="task_package_for_rpa">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${proposalApproved}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_package_to_query_fields" sourceRef="task_package_for_rpa" targetRef="task_rpa_query_fields" />
    <bpmn:sequenceFlow id="flow_query_fields_to_submit" sourceRef="task_rpa_query_fields" targetRef="task_rpa_submit" />
    <bpmn:sequenceFlow id="flow_boundary_submit_to_notify" sourceRef="boundary_submission_failed" targetRef="task_notify_portal_issue" />
    <bpmn:sequenceFlow id="flow_notify_issue_to_timer" sourceRef="task_notify_portal_issue" targetRef="timer_retry_submit" />
    <bpmn:sequenceFlow id="flow_timer_to_retry_gw" sourceRef="timer_retry_submit" targetRef="gw_retry_limit" />
    <bpmn:sequenceFlow id="flow_retry_yes" name="Yes" sourceRef="gw_retry_limit" targetRef="task_rpa_submit">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${retryCount &lt; 3}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_retry_no" name="No" sourceRef="gw_retry_limit" targetRef="end_submission_failed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${retryCount &gt;= 3}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_submit_to_notify_success" sourceRef="task_rpa_submit" targetRef="task_notify_successful_submission" />
    <bpmn:sequenceFlow id="flow_notify_success_to_timer" sourceRef="task_notify_successful_submission" targetRef="timer_monitor_status" />
    <bpmn:sequenceFlow id="flow_timer_monitor_to_check" sourceRef="timer_monitor_status" targetRef="task_rpa_check_status" />
    <bpmn:sequenceFlow id="flow_check_status_to_gw" sourceRef="task_rpa_check_status" targetRef="gw_app_status" />
    <bpmn:sequenceFlow id="flow_status_pending" name="Pending" sourceRef="gw_app_status" targetRef="task_update_farmer_pending">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${status == 'PENDING'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_update_pending_to_timer" sourceRef="task_update_farmer_pending" targetRef="timer_monitor_status" />
    <bpmn:sequenceFlow id="flow_status_approved" name="Approved" sourceRef="gw_app_status" targetRef="task_send_congrats">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${status == 'APPROVED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_congrats_to_end" sourceRef="task_send_congrats" targetRef="end_approved" />
    <bpmn:sequenceFlow id="flow_status_rejected" name="Rejected" sourceRef="gw_app_status" targetRef="task_rpa_get_rejection_reason">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${status == 'REJECTED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_get_reason_to_review" sourceRef="task_rpa_get_rejection_reason" targetRef="task_specialist_reviews_rejection" />
    <bpmn:sequenceFlow id="flow_review_rejection_to_gw" sourceRef="task_specialist_reviews_rejection" targetRef="gw_appeal_worthy" />
    <bpmn:sequenceFlow id="flow_appeal_no" name="No" sourceRef="gw_appeal_worthy" targetRef="task_send_rejection_analysis">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${!isAppealWorthy}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_rejection_analysis_to_end" sourceRef="task_send_rejection_analysis" targetRef="end_rejected_recommendations" />
    <bpmn:sequenceFlow id="flow_appeal_yes" name="Yes" sourceRef="gw_appeal_worthy" targetRef="task_prepare_appeal">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${isAppealWorthy}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_prepare_appeal_to_file" sourceRef="task_prepare_appeal" targetRef="task_rpa_file_appeal" />
    <bpmn:sequenceFlow id="flow_file_appeal_to_notify" sourceRef="task_rpa_file_appeal" targetRef="task_notify_appeal_filed" />
    <bpmn:sequenceFlow id="flow_notify_appeal_to_timer" sourceRef="task_notify_appeal_filed" targetRef="timer_await_appeal" />
    <bpmn:sequenceFlow id="flow_timer_appeal_to_check" sourceRef="timer_await_appeal" targetRef="task_rpa_check_appeal_status" />
    <bpmn:sequenceFlow id="flow_check_appeal_to_gw" sourceRef="task_rpa_check_appeal_status" targetRef="gw_appeal_decision" />
    <bpmn:sequenceFlow id="flow_appeal_approved" name="Approved" sourceRef="gw_appeal_decision" targetRef="task_notify_appeal_won">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${appealStatus == 'APPROVED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_appeal_won_to_end" sourceRef="task_notify_appeal_won" targetRef="end_appeal_approved" />
    <bpmn:sequenceFlow id="flow_appeal_rejected" name="Rejected" sourceRef="gw_appeal_decision" targetRef="task_send_final_report">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${appealStatus == 'REJECTED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_final_report_to_end" sourceRef="task_send_final_report" targetRef="end_final_rejection" />
    <bpmn:sequenceFlow id="flow_grants_found_to_present" name="Yes" sourceRef="gw_grants_found" targetRef="task_present_options">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=${grantsFound}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_present_to_select" sourceRef="task_present_options" targetRef="task_farmer_selects_grant" />
    <bpmn:sequenceFlow id="flow_select_to_deep_dive" sourceRef="task_farmer_selects_grant" targetRef="task_deep_dive_assessment" />
    <bpmn:sequenceFlow id="flow_deep_dive_to_gw_reqs_met" sourceRef="task_deep_dive_assessment" targetRef="gw_requirements_met" />
  </bpmn:process>
