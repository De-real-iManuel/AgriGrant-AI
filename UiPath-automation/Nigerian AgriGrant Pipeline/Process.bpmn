        <uipath:inputOutput id="monitoringAndEvaluation4" name="monitoringAndEvaluation" type="jsonSchema" elementId="task_compose_proposal"><![CDATA[{"type":"object","description":"M&E framework for tracking project progress. Populated when full proposal is generated.","properties":{"approach":{"type":"string","description":"100–150 word description of the overall M&E approach."},"keyIndicators":{"type":"array","description":"3–5 KPIs with baselines, targets, and measurement methods.","items":{"type":"object","properties":{"indicator":{"type":"string","description":"Name of the performance indicator."},"baseline":{"type":"string","description":"Starting value before the project."},"target":{"type":"string","description":"Expected value by project end."},"measurementMethod":{"type":"string","description":"How this will be measured."}}}},"reportingSchedule":{"type":"string","description":"Reporting frequency and format (e.g., 'Monthly activity reports, quarterly financial reports, final impact report at project close')."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
