        <uipath:inputOutput id="projectObjectives4" name="projectObjectives" type="jsonSchema" subType="string" elementId="task_compose_proposal"><![CDATA[{"type":"array","description":"3–5 SMART objectives (Specific, Measurable, Achievable, Relevant, Time-bound). Each written as a complete action statement. Empty array when documentType is 'application_letter'.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="methodology4" name="methodology" type="jsonSchema" elementId="task_compose_proposal"><![CDATA[{"type":"object","description":"Structured methodology with phased activities. Populated when documentType is 'full_proposal' or 'both'.","properties":{"overview":{"type":"string","description":"100–150 word overview of the overall approach."},"activities":{"type":"array","description":"Phased activity plan covering the full project duration.","items":{"type":"object","properties":{"phase":{"type":"string","description":"Phase name (e.g., 'Phase 1: Mobilization and Procurement')."},"timeline":{"type":"string","description":"Time period for this phase (e.g., 'Month 1–3')."},"activities":{"type":"array","description":"List of specific activities in this phase.","items":{"type":"string"}}}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="budgetBreakdown4" name="budgetBreakdown" type="jsonSchema" subType="object" elementId="task_compose_proposal"><![CDATA[{"type":"array","description":"Itemized budget summing to requestedAmountNGN. Empty array when documentType is 'application_letter'.","items":{"type":"object","properties":{"lineItem":{"type":"string","description":"Budget item name (e.g., 'Irrigation Equipment', 'Labour Costs')."},"description":{"type":"string","description":"Brief description of what this covers."},"amountNGN":{"type":"number","description":"Amount in NGN for this line item."},"percentageOfTotal":{"type":"string","description":"Percentage of total budget (e.g., '25%')."},"justification":{"type":"string","description":"1–2 sentence justification for this expenditure."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="budgetNarrative4" name="budgetNarrative" type="string" elementId="task_compose_proposal" />
        <uipath:inputOutput id="expectedOutcomes4" name="expectedOutcomes" type="jsonSchema" elementId="task_compose_proposal"><![CDATA[{"type":"object","description":"Structured outcomes covering direct outputs, impact, and beneficiary breakdown. Populated when full proposal is generated.","properties":{"directOutputs":{"type":"array","description":"Concrete measurable deliverables.","items":{"type":"string"}},"impactStatements":{"type":"array","description":"Broader impact statements.","items":{"type":"string"}},"beneficiaries":{"type":"object","properties":{"directBeneficiaries":{"type":"integer","description":"Number of people directly benefiting."},"indirectBeneficiaries":{"type":"integer","description":"Number of people indirectly benefiting."},"womenBeneficiaries":{"type":"string","description":"Proportion or number of women beneficiaries (e.g., '60% women', '120 women farmers')."},"youthBeneficiaries":{"type":"string","description":"Proportion or number of youth beneficiaries (e.g., '35% youth aged 18–35')."}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
