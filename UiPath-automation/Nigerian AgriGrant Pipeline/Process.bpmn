        <uipath:inputOutput id="confirmationPackage5" name="confirmationPackage" type="jsonSchema" elementId="task_notify_successful_submission"><![CDATA[{"type":"object","description":"Present only when agentAction is 'generate-confirmation'.","properties":{"congratulatoryMessage":{"type":"string"},"smsMessage":{"type":"string"},"whatsappMessage":{"type":"string"},"submissionSummaryCard":{"type":"object","properties":{"farmerName":{"type":"string"},"grantName":{"type":"string"},"projectTitle":{"type":"string"},"amountRequested":{"type":"string"},"submissionDate":{"type":"string"},"referenceNumber":{"type":"string"},"expectedResponseTime":{"type":"string"},"nextStep":{"type":"string"}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="reminderSchedule5" name="reminderSchedule" type="jsonSchema" elementId="task_notify_successful_submission"><![CDATA[{"type":"object","description":"Present only when agentAction is 'set-reminders'.","properties":{"totalReminders":{"type":"integer"},"reminders":{"type":"array","items":{"type":"object","properties":{"reminderNumber":{"type":"integer"},"triggerEvent":{"type":"string"},"suggestedDate":{"type":"string"},"channel":{"type":"string","enum":["push-notification","SMS","WhatsApp","Email"]},"message":{"type":"string"},"actionRequired":{"type":"string"}}}},"calendarSummary":{"type":"string"}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="trackingAndFollowUp5" name="trackingAndFollowUp" type="jsonSchema" elementId="task_notify_successful_submission"><![CDATA[{"type":"object","description":"Present only when agentAction is 'track-and-follow-up'.","properties":{"statusAssessment":{"type":"string"},"urgencyLevel":{"type":"string","enum":["Routine","Follow-Up Due","Action Required","Urgent"]},"followUpEmailDraft":{"type":"string"},"followUpWhatsappMessage":{"type":"string"},"phoneScriptForFollowUp":{"type":"string"},"nextActions":{"type":"array","items":{"type":"object","properties":{"action":{"type":"string"},"timeline":{"type":"string"},"channel":{"type":"string"}}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="additionalInfoResponse5" name="additionalInfoResponse" type="jsonSchema" elementId="task_notify_successful_submission"><![CDATA[{"type":"object","description":"Present only when agentAction is 'handle-additional-info-request'.","properties":{"acknowledgementLetter":{"type":"string"},"itemsToProvide":{"type":"array","items":{"type":"object","properties":{"item":{"type":"string"},"howToObtain":{"type":"string"},"estimatedTimeToObtain":{"type":"string"}}}},"farmerInstructions":{"type":"string"},"responseDeadlineSuggestion":{"type":"string"}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="rejectionResponse5" name="rejectionResponse" type="jsonSchema" elementId="task_notify_successful_submission"><![CDATA[{"type":"object","description":"Present only when agentAction is 'generate-rejection-response'.","properties":{"farmerSupportMessage":{"type":"string"},"rejectionAnalysis":{"type":"string"},"appealLetter":{"type":"string"},"improvementPlan":{"type":"array","items":{"type":"string"}},"alternativeOptions":{"type":"array","items":{"type":"string"}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
