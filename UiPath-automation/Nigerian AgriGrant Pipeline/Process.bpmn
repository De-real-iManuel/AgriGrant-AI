        <uipath:inputOutput id="projectDescription3" name="projectDescription" type="string" elementId="task_collect_grant_details" />
        <uipath:inputOutput id="projectObjectives2" name="projectObjectives" type="jsonSchema" subType="string" elementId="task_collect_grant_details"><![CDATA[{"type":"array","description":"3–5 SMART objectives (Specific, Measurable, Achievable, Relevant, Time-bound). Each written as a complete action statement. Empty array when documentType is 'application_letter'.","items":{"type":"string"},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="methodology2" name="methodology" type="jsonSchema" elementId="task_collect_grant_details"><![CDATA[{"type":"object","description":"Structured methodology with phased activities. Populated when documentType is 'full_proposal' or 'both'.","properties":{"overview":{"type":"string","description":"100–150 word overview of the overall approach."},"activities":{"type":"array","description":"Phased activity plan covering the full project duration.","items":{"type":"object","properties":{"phase":{"type":"string","description":"Phase name (e.g., 'Phase 1: Mobilization and Procurement')."},"timeline":{"type":"string","description":"Time period for this phase (e.g., 'Month 1–3')."},"activities":{"type":"array","description":"List of specific activities in this phase.","items":{"type":"string"}}}}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="budgetBreakdown2" name="budgetBreakdown" type="jsonSchema" subType="object" elementId="task_collect_grant_details"><![CDATA[{"type":"array","description":"Itemized budget summing to requestedAmountNGN. Empty array when documentType is 'application_letter'.","items":{"type":"object","properties":{"lineItem":{"type":"string","description":"Budget item name (e.g., 'Irrigation Equipment', 'Labour Costs')."},"description":{"type":"string","description":"Brief description of what this covers."},"amountNGN":{"type":"number","description":"Amount in NGN for this line item."},"percentageOfTotal":{"type":"string","description":"Percentage of total budget (e.g., '25%')."},"justification":{"type":"string","description":"1–2 sentence justification for this expenditure."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
