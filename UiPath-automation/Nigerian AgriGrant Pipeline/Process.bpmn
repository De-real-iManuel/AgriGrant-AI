        <uipath:inputOutput id="applicationLetters2" name="applicationLetters" type="jsonSchema" subType="object" elementId="task_collect_grant_details"><![CDATA[{"type":"array","description":"Array of ready-to-submit formal application letters. Populated when documentType is 'application_letter' or 'both'. Empty array [] when documentType is 'full_proposal'.","items":{"type":"object","properties":{"grantName":{"type":"string","description":"Name of the grant this letter is for."},"letterType":{"type":"string","description":"Format of the letter based on grantCategory: 'formal_government' for CBN/BOA/FMARD, 'state_ministry' for state programs, 'microfinance' for NIRSAL/MFB programs, 'ngo_eoi' for NGO expression of interest, 'development_bank' for World Bank/IFAD/AfDB.","enum":["formal_government","state_ministry","microfinance","ngo_eoi","development_bank"]},"recipientAddress":{"type":"string","description":"Full recipient address block for the letter header (e.g., 'The Director, Development Finance Department, Central Bank of Nigeria, CBN Headquarters, Abuja')."},"subject":{"type":"string","description":"Subject line of the letter in uppercase (e.g., 'RE: APPLICATION FOR THE CBN ANCHOR BORROWERS PROGRAMME — RICE AND MAIZE PRODUCTION, KANO STATE')."},"letterBody":{"type":"string","description":"Complete formatted application letter body, ready to print and sign. Includes: farmer address header, date (June 2026), recipient address, subject line, salutation, 4–5 body paragraphs (introduction, farm profile, funding need, grant alignment, closing), complimentary close, and signature block. 400–600 words. Must be complete — not a template, not a draft."},"enclosureList":{"type":"array","description":"List of all supporting documents to attach with the letter (e.g., 'Certified copy of NIN slip', 'CAC Certificate', 'Land document or C of O', 'Recent passport photograph', 'Bank statement (last 6 months)').","items":{"type":"string"}},"recommendedSubmissionMethod":{"type":"string","description":"Step-by-step instructions on how to physically or digitally submit this specific letter (e.g., 'Print 3 copies. Hand-deliver to the nearest CBN branch or participating microfinance bank. Request an acknowledgement receipt at submission.')."},"wordCount":{"type":"integer","description":"Approximate word count of the letterBody."}}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
        <uipath:inputOutput id="proposalTitle2" name="proposalTitle" type="string" elementId="task_collect_grant_details" />
        <uipath:inputOutput id="projectDurationMonths2" name="projectDurationMonths" type="integer" elementId="task_collect_grant_details" />
        <uipath:inputOutput id="coverPage2" name="coverPage" type="jsonSchema" elementId="task_collect_grant_details"><![CDATA[{"type":"object","description":"Structured cover page metadata. Populated when documentType is 'full_proposal' or 'both'. Null object when documentType is 'application_letter'.","properties":{"projectTitle":{"type":"string","description":"Full project title as it appears on the cover page."},"submittedBy":{"type":"string","description":"Applicant or organization name."},"submittedTo":{"type":"string","description":"Granting organization name and department."},"projectLocation":{"type":"string","description":"State and LGA of the project."},"projectDuration":{"type":"string","description":"Project duration in readable format (e.g., '18 months: January 2026 – June 2027')."},"totalFundingRequested":{"type":"string","description":"Amount in NGN formatted with commas (e.g., 'NGN 5,000,000')."},"submissionDate":{"type":"string","description":"Submission date in format 'Month YYYY'."}},"$schema":"http://json-schema.org/draft-07/schema#"}]]></uipath:inputOutput>
